{% comment %}
  Renders a collection card for the collection slider.
  Accepts:
  - block: {Object} The block object
  - title_layout: {String} The layout style ('layout-1' or 'layout-2')
  - content_style: {String} The content style ('pill' or 'default')
  - layout: {String} The layout style ('title_with_button' or 'button_only')
{% endcomment %}

{%  liquid 
  if section.settings.content_style == 'pill'
    assign slide_class = 'wg-cls-2'
  else
    assign slide_class = 'wg-cls style-2'
  endif
%}


{%- assign collection = block.settings.collection -%}
{%- assign custom_image = block.settings.custom_image -%}
{%- assign button_text = block.settings.button_text | default: 'Shop now' -%}
{% if section.index == 2 %}
  {% assign loading = 'eager' %}
  {% assign fetchpriority = 'high' %}
{% else %}
  {% assign loading = 'lazy' %}
  {% assign fetchpriority = 'low' %}
  {% assign class = 'lazyload' %}
{% endif %}

<div class="{{ slide_class }} {% if title_layout == 'layout-2' %}type-space-2{% endif %} d-flex hover-img">
  <a href="{{ collection.url | default: '#' }}" class="image img-style w-100">
    {% if custom_image != blank %}
      <img
        srcset="
          {%- if custom_image.width >= 165 -%}{{ custom_image | image_url: width: 165 }} 165w,{%- endif -%}
          {%- if custom_image.width >= 330 -%}{{ custom_image | image_url: width: 330 }} 330w,{%- endif -%}
          {%- if custom_image.width >= 535 -%}{{ custom_image | image_url: width: 535 }} 535w,{%- endif -%}
          {%- if custom_image.width >= 750 -%}{{ custom_image | image_url: width: 750 }} 750w,{%- endif -%}
          {%- if custom_image.width >= 1000 -%}{{ custom_image | image_url: width: 1000 }} 1000w,{%- endif -%}
          {%- if custom_image.width >= 1500 -%}{{ custom_image | image_url: width: 1500 }} 1500w,{%- endif -%}
          {%- if custom_image.width >= 3000 -%}{{ custom_image | image_url: width: 3000 }} 3000w,{%- endif -%}
          {{ custom_image | image_url }} {{ custom_image.width }}w
        "
        src="{{ custom_image | image_url: width: 1500 }}"
        sizes="
          (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: columns }}px,
          (min-width: 750px) {% if columns > 1 %}calc((100vw - 10rem) / 2){% else %}calc(100vw - 10rem){% endif %},
          calc(100vw - 3rem)
        "
        alt="{{ custom_image.alt | escape }}"
        height="{{ custom_image.height }}"
        width="{{ custom_image.width }}"
        class="motion-reduce {{ class }}"
        loading="{{ loading }}"
        fetchpriority="{{ fetchpriority }}"
        >
    {% elsif collection.featured_image != blank %}
      <img
        srcset="
          {%- if collection.featured_image.width >= 165 -%}{{ collection.featured_image | image_url: width: 165 }} 165w,{%- endif -%}
          {%- if collection.featured_image.width >= 330 -%}{{ collection.featured_image | image_url: width: 330 }} 330w,{%- endif -%}
          {%- if collection.featured_image.width >= 535 -%}{{ collection.featured_image | image_url: width: 535 }} 535w,{%- endif -%}
          {%- if collection.featured_image.width >= 750 -%}{{ collection.featured_image | image_url: width: 750 }} 750w,{%- endif -%}
          {%- if collection.featured_image.width >= 1000 -%}{{ collection.featured_image | image_url: width: 1000 }} 1000w,{%- endif -%}
          {%- if collection.featured_image.width >= 1500 -%}{{ collection.featured_image | image_url: width: 1500 }} 1500w,{%- endif -%}
          {%- if collection.featured_image.width >= 3000 -%}{{ collection.featured_image | image_url: width: 3000 }} 3000w,{%- endif -%}
          {{ collection.featured_image | image_url }} {{ collection.featured_image.width }}w
        "
        src="{{ collection.featured_image | image_url: width: 1500 }}"
        sizes="
          (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: columns }}px,
          (min-width: 750px) {% if columns > 1 %}calc((100vw - 10rem) / 2){% else %}calc(100vw - 10rem){% endif %},
          calc(100vw - 3rem)
        "
        alt="{{ collection.featured_image.alt | escape }}"
        height="{{ collection.featured_image.height }}"
        width="{{ collection.featured_image.width }}"
        class="motion-reduce {{ class }}"
        loading="{{ loading }}"
        fetchpriority="{{ fetchpriority }}"
      >
    {% else %}
      {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {% endif %}
  </a>
  {% if content_style == 'pill' %}
    <div class="cls-content_wrap {% if title_layout == 'layout-1' %}b-16{% endif %}">
      {% if layout == 'title_with_button' %}
      <div class="cls-content">
        <a href="{{ collection.url | default: '#' }}" class="tag_cls {% if title_layout == 'layout-1' %}h3{% else %}h2 type-semibold{% endif %} link">
          {{ collection.title | default: 'Collection Title' }}
        </a>
        <span class="br-line type-vertical"></span>
        <a href="{{ collection.url | default: '#' }}" class="tf-btn-line text-nowrap">
          {{ button_text }}
        </a>
      </div>
      {% elsif layout == 'button_only' %}
        <a href="{{ collection.url | default: '#' }}" class="tf-btn btn-white animate-btn animate-dark rounded-0 type-small-2">
          {{ button_text }}
        </a>
      {% endif %}

    </div>
  {% else %}
    <div class="cls-content">
      <a href="{{ collection.url | default: '#' }}" class="tf-btn-line style-white line-bot-0">
        <span class="h3 fw-bold">
          {{ collection.title | default: 'Collection Title' }}
        </span>
      </a>
    </div>
  {% endif %}
</div>
