{% doc %}
  Renders a product swiper grid for a collection.

  @param {string} collection_ref - Collection reference from settings
  @param {number} products_limit - Max products to show
  @param {string} grid_rows - Number of rows in the swiper grid
  @param {boolean} hide_pagination_desktop - Hide pagination on desktop
  @param {number} slides_desktop - Number of slides to show on desktop
  @param {number} slides_tablet - Number of slides to show on tablet
  @param {number} slides_mobile - Number of slides to show on mobile
  @param {string} countdown_size - Size of the countdown timer
  @param {string} product_title_size - Size of the product title
{% enddoc %}

<div
  dir="ltr"
  class="swiper tf-swiper wow fadeInUp"
  data-preview="{{ slides_desktop }}"
  data-tablet="{{ slides_tablet }}"
  data-mobile-sm="{{ slides_mobile }}"
  data-mobile="2"
  data-space-lg="48"
  data-space-md="30"
  data-space="12"
  data-pagination="2"
  data-pagination-sm="2"
  data-pagination-md="3"
  data-pagination-lg="4"
  data-grid="{{ grid_rows }}"
>
  <div class="swiper-wrapper">
    {% if collection_ref != blank %}
      {% assign collection_products = collections[collection_ref].products %}
      {% for product in collection_products limit: products_limit %}
        <div class="swiper-slide">
          {% render 'card-product', 
            product: product, 
            show_wishlist: true, 
            show_compare: true, 
            show_quick_view: true,
            show_add_to_cart: true,
            countdown_size: countdown_size,
            product_title_size: product_title_size
          %}
        </div>
      {% endfor %}
    {% else %}
      {% for i in (1..4) %}
        <div class="swiper-slide">
          <div class="card-product">
            <div class="card-product_wrapper">
              <div class="product-img placeholder">
                {{ 'product-apparel-' | append: i | placeholder_svg_tag: 'placeholder-svg w-100' }}
              </div>
            </div>
            <div class="card-product_info">
              <div class="name-product {{ product_title_size }} link">{{ 'onboarding.product_title' | t }}</div>
              <div class="price-wrap">
                <span class="price-new {{ product_title_size }}">{{ 1999 | money }}</span>
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    {% endif %}
  </div>
  <div class="sw-dot-default tf-sw-pagination {% if hide_pagination_desktop %}d-xl-none{% endif %}"></div>
</div>
