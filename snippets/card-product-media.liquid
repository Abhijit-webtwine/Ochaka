<a href="{{ product.url }}" class="product-img w-100 h-100">
  {%- assign main_image = product.featured_image | default: product.images[0] -%}
  {%- assign hover_image = product.images[1] | default: main_image -%}

  <img
    srcset="
      {%- if main_image.width >= 165 -%}{{ main_image | image_url: width: 165 }} 165w,{%- endif -%}
      {%- if main_image.width >= 360 -%}{{ main_image | image_url: width: 360 }} 360w,{%- endif -%}
      {%- if main_image.width >= 533 -%}{{ main_image | image_url: width: 533 }} 533w,{%- endif -%}
      {%- if main_image.width >= 720 -%}{{ main_image | image_url: width: 720 }} 720w,{%- endif -%}
      {%- if main_image.width >= 940 -%}{{ main_image | image_url: width: 940 }} 940w,{%- endif -%}
      {%- if main_image.width >= 1066 -%}{{ main_image | image_url: width: 1066 }} 1066w,{%- endif -%}
      {{ main_image | image_url }} {{ main_image.width }}w
    "
    src="{{ main_image | image_url: width: 533 }}"
    data-src="{{ main_image | image_url: width: 200 }}"
    sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
    alt="{{ main_image.alt | escape }}"
    class="motion-reduce img-product lazyload"
    loading="lazy"
    width="{{ main_image.width }}"
    height="{{ main_image.height }}"
  >

  <img
    srcset="
      {%- if hover_image.width >= 165 -%}{{ hover_image | image_url: width: 165 }} 165w,{%- endif -%}
      {%- if hover_image.width >= 360 -%}{{ hover_image | image_url: width: 360 }} 360w,{%- endif -%}
      {%- if hover_image.width >= 533 -%}{{ hover_image | image_url: width: 533 }} 533w,{%- endif -%}
      {%- if hover_image.width >= 720 -%}{{ hover_image | image_url: width: 720 }} 720w,{%- endif -%}
      {%- if hover_image.width >= 940 -%}{{ hover_image | image_url: width: 940 }} 940w,{%- endif -%}
      {%- if hover_image.width >= 1066 -%}{{ hover_image | image_url: width: 1066 }} 1066w,{%- endif -%}
      {{ hover_image | image_url }} {{ hover_image.width }}w
    "
    src="{{ hover_image | image_url: width: 533 }}"
    data-src="{{ hover_image | image_url: width: 200 }}"
    sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 130 | divided_by: 4 }}px, (min-width: 990px) calc((100vw - 130px) / 4), (min-width: 750px) calc((100vw - 120px) / 3), calc((100vw - 35px) / 2)"
    alt="{{ hover_image.alt | escape }}"
    class="motion-reduce img-hover lazyload"
    loading="lazy"
    width="{{ hover_image.width }}"
    height="{{ hover_image.height }}"
  >
</a>
