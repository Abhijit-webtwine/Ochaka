      "label": "Spacing Desktop",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "space_tablet",
      "label": "Spacing Tablet",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "space_mobile",
      "label": "Spacing Mobile",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
