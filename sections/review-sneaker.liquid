{% style %}
  .section-{{ section.id }}-review-sneaker {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-review-sneaker {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-review-sneaker {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }
{% endstyle %}

<section class="section-{{ section.id }}-review-sneaker">
  <div class="container">
    {% if section.settings.header_layout == 'with_subtitle' %}
      <div class="sect-title text-center wow fadeInUp">
        {% if section.settings.heading != blank %}
          <h1 class="s-title mb-8">{{ section.settings.heading }}</h1>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="s-subtitle h6">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.header_layout == 'with_button' %}
      <div class="sect-title type-4">
        <div class="flex-sm-1 wow fadeInUp">
          <h2 class="s-title fw-normal">{{ section.settings.heading }}</h2>
        </div>
        <div class="group-btn-slider wow fadeInUp" data-wow-delay="0.1s">
          <div class="tf-sw-nav style-2 type-small nav-prev-swiper">
            <i class="icon icon-caret-left"></i>
          </div>
          <div class="tf-sw-nav style-2 type-small nav-next-swiper">
            <i class="icon icon-caret-right"></i>
          </div>
        </div>
      </div>
    {% endif %}

    <div dir="ltr" class="swiper tf-swiper wow fadeInUp" 
      data-preview="{{ section.settings.slides_desktop }}"
      data-tablet="{{ section.settings.slides_tablet }}"
      data-mobile-sm="{{ section.settings.slides_mobile }}"
      data-mobile="1"
      data-space-lg="{{ section.settings.space_desktop }}"
      data-space-md="{{ section.settings.space_tablet }}"
      data-space="{{ section.settings.space_mobile }}"
      data-pagination="1" 
      data-pagination-sm="2"
      data-pagination-md="2" 
      data-pagination-lg="3">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="testimonial-V04">
              <div class="tes_content">
                <div class="author-image">
                  {% if block.settings.author_image != blank %}
                    {{ block.settings.author_image | image_url: width: 150 | image_tag:
                      loading: 'lazy',
                      widths: '75,100,150,200',
                      sizes: '150px',
                      alt: block.settings.author_image.alt,
                      class: 'author-img'
                    }}
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                </div>
                {% if block.settings.title != blank %}
                  <h4 class="tes_title fw-semibold">{{ block.settings.title }}</h4>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p class="tes_text h6">
                    “{{ block.settings.text }}”
                  </p>
                {% endif %}
                {% if block.settings.author != blank %}
                  <p class="tes_author h4">{{ block.settings.author }}</p>
                {% endif %}
                {% render 'testimonial-review', rating: block.settings.rating %}
              </div>
              {% if block.settings.product != blank %}
                {% assign product = block.settings.product %}
                <div class="tes_product">
                  <a href="{{ product.url }}" class="product-image">
                    {% if product.featured_image != blank %}
                      <img class="lazyload" 
                        src="{{ product.featured_image | image_url }}" 
                        data-src="{{ product.featured_image | image_url }}" 
                        alt="{{ product.title | escape }}"
                      >
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %}
                  </a>
                  <div class="product-infor">
                    <h5 class="prd_name">
                      <a href="{{ product.url }}" class="link">
                        {{ product.title }}
                      </a>
                    </h5>
                    <h6 class="prd_price">{{ product.price | money_without_trailing_zeros }}</h6>
                  </div>
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Review Sneaker",
  "settings": [
    {
      "type": "select",
      "id": "header_layout",
      "label": "Header Layout",
      "options": [
      {
      "value": "with_subtitle",
      "label": "With Subtitle"
      },
      {
      "value": "with_button",
      "label": "With Button"
      }
      ],
      "default": "with_subtitle"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Up to 50% off Lorem ipsum dolor sit amet, consectetur adipiscing elit"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Slides Desktop",
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Slides Tablet",
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Slides Mobile",
      "default": 1
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "space_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Spacing Desktop",
      "default": 48
    },
    {
      "type": "range",
      "id": "space_tablet",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Spacing Tablet",
      "default": 30
    },
    {
      "type": "range",
      "id": "space_mobile",
      "min": 0,
      "max": 50,
      "step": 1,
      "label": "Spacing Mobile",
      "default": 12
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Top Tablet",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom Tablet",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Dedicated service"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "The build quality is excellent and everything works smoothly. I can feel the difference compared to other brands."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Brooklyn Simmons"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review Sneaker",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "title": "Dedicated service",
            "text": "The build quality is excellent and everything works smoothly. I can feel the difference compared to other brands.",
            "author": "Brooklyn Simmons",
            "rating": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "title": "Best Product Quality",
            "text": "The support from ACIS has been outstanding. Anytime we had a question or needed help, their team responded quickly and professionally.",
            "author": "Mas Shin",
            "rating": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "title": "Exceptional Reliability",
            "text": "No surprises, just consistent and dependable performance every single time without fail.",
            "author": "Sil Vox",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}