{% style %}
  .section-{{ section.id }}-review-book {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-review-book {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-review-book {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  /* Pre-initialization Swiper styles to prevent layout shift */
  .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    flex-wrap: nowrap;
    overflow: hidden;
    gap: {{ section.settings.space_mobile }}px;
  }
  .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
    width: calc((100% - ({{ section.settings.slides_mobile }} - 1) * {{ section.settings.space_mobile }}px) / {{ section.settings.slides_mobile }});
    flex: 0 0 auto;
  }
  
  @media (min-width: 768px) {
    .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-wrapper {
      gap: {{ section.settings.space_tablet }}px;
    }
    .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
      width: calc((100% - ({{ section.settings.slides_tablet }} - 1) * {{ section.settings.space_tablet }}px) / {{ section.settings.slides_tablet }});
    }
  }
  
  @media (min-width: 1200px) {
    .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-wrapper {
      gap: {{ section.settings.space_desktop }}px;
    }
    .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
      width: calc((100% - ({{ section.settings.slides_desktop }} - 1) * {{ section.settings.space_desktop }}px) / {{ section.settings.slides_desktop }});
    }
  }
{% endstyle %}

<section class="section-{{ section.id }}-review-book section-{{ section.id }}-swiper">
  <div class="container">
    <div class="sect-title type-4 align-items-start">
      <div class="flex-sm-1 wow fadeInUp">
        {% if section.settings.heading != blank %}
          <h2 class="s-title fw-normal">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
      <div class="group-btn-slider wow fadeInUp" data-wow-delay="0.1s">
        <div class="tf-sw-nav style-2 hv-primary primary-6 type-small nav-prev-swiper">
          <i class="icon icon-caret-left"></i>
        </div>
        <div class="tf-sw-nav style-2 hv-primary primary-6 type-small nav-next-swiper">
          <i class="icon icon-caret-right"></i>
        </div>
      </div>
    </div>
    <div dir="ltr" class="swiper tf-swiper" 
      data-preview="{{ section.settings.slides_desktop }}"
      data-tablet="{{ section.settings.slides_tablet }}"
      data-mobile-sm="{{ section.settings.slides_mobile }}"
      data-mobile="1"
      data-space-lg="{{ section.settings.space_desktop }}"
      data-space-md="{{ section.settings.space_tablet }}"
      data-space="{{ section.settings.space_mobile }}"
      data-pagination="1" 
      data-pagination-sm="1"
      data-pagination-md="2" 
      data-pagination-lg="2">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="testimonial-V02 type-space-3 hover-img wow fadeInUp">
              {% if block.settings.product != blank %}
                {% assign product = block.settings.product %}
                <div class="tes_product">
                  <div class="product-image img-style">
                    {% if product.featured_image != blank %}
                      <img class="lazyload" 
                        src="{{ product.featured_image | image_url }}" 
                        data-src="{{ product.featured_image | image_url }}" 
                        alt="{{ product.title | escape }}"
                        width="600"
                        height="{{ 600 | divided_by: product.featured_image.aspect_ratio | round }}"
                      >
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %}
                  </div>
                </div>
                <div class="tes_content">
                  <h4 class="tes_title"><a href="{{ product.url }}" class="link">{{ product.title }}</a></h4>
                  <h6 class="prd_price fw-semibold">{{ product.price | money_without_trailing_zeros }}</h6>
                  {% if block.settings.text != blank %}
                    <p class="tes_text h4">
                      “{{ block.settings.text }}”
                    </p>
                  {% endif %}
                  <div class="tes_author">
                    {% if block.settings.author != blank %}
                      <p class="author-name h4">{{ block.settings.author }}</p>
                    {% endif %}
                    {% if block.settings.verified %}
                      <span class="d-flex">
                        <i class="author-verified icon-check-circle fs-24"></i>
                      </span>
                    {% endif %}
                  </div>
                  {% render 'testimonial-review', rating: block.settings.rating %}
                </div>
              {% else %}
                <div class="tes_content">
                    <h4 class="tes_title">Product Title</h4>
                  {% if block.settings.text != blank %}
                    <p class="tes_text h4">
                      “{{ block.settings.text }}”
                    </p>
                  {% endif %}
                  <div class="tes_author">
                    {% if block.settings.author != blank %}
                      <p class="author-name h4">{{ block.settings.author }}</p>
                    {% endif %}
                    {% if block.settings.verified %}
                      <span class="d-flex">
                        <i class="author-verified icon-check-circle fs-24"></i>
                      </span>
                    {% endif %}
                  </div>
                  {% render 'testimonial-review', rating: block.settings.rating %}
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Review Book",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Says!"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "label": "Slides Desktop",
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Slides Tablet",
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Slides Mobile",
      "default": 1
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "space_desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Spacing Desktop",
      "default": 48
    },
    {
      "type": "range",
      "id": "space_tablet",
      "min": 0,
      "max": 100,
      "step": 1,
      "label": "Spacing Tablet",
      "default": 32
    },
    {
      "type": "range",
      "id": "space_mobile",
      "min": 0,
      "max": 50,
      "step": 1,
      "label": "Spacing Mobile",
      "default": 12
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Top Tablet",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom Tablet",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "The support from ACIS has been outstanding. Anytime we had a question or needed help, their team responded quickly and professionally."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Brooklyn Simmons"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified Purchase",
          "default": true
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Select product to display its image and title."
        }
      ]
