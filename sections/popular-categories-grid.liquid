<section class="flat-spacing">
  <div class="container">
    <div class="sect-title text-center wow fadeInUp">
      <h2 class="s-title h1 fw-medium mb-8">{{ section.settings.heading }}</h2>
      <p class="s-subtitle h6">{{ section.settings.subheading }}</p>
    </div>
    <div class="watch-grid wow fadeInUp">
      {%- for block in section.blocks -%}
        {%- liquid
          assign position_class = blank
            case forloop.index
              when 1
                assign position_class = 'aa'
              when 2
                assign position_class = 'bb'
              when 3
                assign position_class = 'cc'
              when 4
                assign position_class = 'dd'
              else
                assign position_class = 'ee'
            endcase
        -%}
        <div class="item {{ position_class }} box-image_category hover-img" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.collection.url | default: '#' }}" class="box-image_image img-style">
            {%- if block.settings.image != blank -%}
              <img
                class="lazyload"
                src="{{ block.settings.image | image_url: width: 300 }}"
                data-src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
                loading="lazy"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
            {%- endif -%}
          </a>
          <div class="box-image_content">
            <a href="{{ block.settings.collection.url | default: '#' }}" class="tf-btn btn-white animate-btn animate-dark rounded-0 px-xxl-32">
              <span class="h6 fw-medium">{{ block.settings.title }}</span>
            </a>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Popular Categories Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Popular Categories"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Up to 50% off lorem ipsum dolor sit amet"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category Name"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Popular Categories Grid",
      "category": "Custom",
      "blocks": [
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        },
        {
          "type": "category"
        }
      ]
    }
  ]
}
{% endschema %}
