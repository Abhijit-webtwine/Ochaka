          "settings": {
            "author_name": "Sil Vox",
            "review_text": "ACIS consistently provides fast, professional support whenever we need it. Their team is knowledgeable and always ready to help with any issue, big or small. We really appreciate their reliable partnership."
          }
        }
      ]
    }
  ]
}
{% endschema %}
