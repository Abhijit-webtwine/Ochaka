{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  /* Pre-initialization Swiper styles to prevent layout shift */
  .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    flex-wrap: nowrap;
    overflow: hidden;
    gap: 12px;
  }
  .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
    width: 100%;
    flex: 0 0 auto;
  }

  @media (min-width: 768px) {
    .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-wrapper {
      gap: 24px;
    }
    .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
      width: calc((100% - 24px) / 2);
    }
  }

  @media (min-width: 1025px) {
    .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-wrapper {
      gap: 48px;
    }
    .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
      width: calc((100% - 2 * 48px) / 3);
    }
  }
{%- endstyle -%}

<section class="flat-spacing section-{{ section.id }}-padding section-{{ section.id }}-swiper">
  <div class="container">
    <div dir="ltr" class="swiper tf-swiper wrap-sw-over wow fadeInUp" 
      data-preview="3" 
      data-tablet="2" 
      data-mobile-sm="1" 
      data-mobile="1"
      data-space-lg="48" 
      data-space-md="24" 
      data-space="12" 
      data-pagination="1" 
      data-pagination-sm="2" 
      data-pagination-md="2"
      data-pagination-lg="3">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div class="swiper-slide" {{ block.shopify_attributes }}>
            <div>
               <div class="sect-title type-3 type-2">
                 {%- if block.settings.heading != blank -%}
                   <h2 class="s-title text-nowrap type-semibold">{{ block.settings.heading }}</h2>
                 {%- elsif block.settings.collection != blank -%}
                   <h2 class="s-title text-nowrap type-semibold">{{ block.settings.collection.title }}</h2>
                 {%- endif -%}
                 {%- assign view_all_url = block.settings.link | default: block.settings.collection.url -%}
                 {%- if view_all_url != blank -%}
                   <a href="{{ view_all_url }}" class="tf-btn-icon h6 fw-medium text-nowrap">
                     {{- block.settings.btn_text | default: 'View All Product' -}}
                     <i class="icon icon-caret-circle-right"></i>
                   </a>
                 {%- endif -%}
               </div>
               <div class="list-ver gap-xl-40">
                 {%- if block.settings.collection != blank -%}
                   {%- for product in block.settings.collection.products limit: block.settings.product_limit -%}
                     {% render 'card-product-mini', product: product %}
                   {%- endfor -%}
                 {%- else -%}
                   {%- for i in (1..3) -%}
                     <div class="card-product product-style_list-mini type-2 hover-img">
                       <div class="card-product_wrapper">
                         <div class="product-img img-style">
                           {{ 'product-apparel-' | append: i | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                         </div>
                       </div>
                       <div class="card-product_info">
                         <h6 class="name-product">Example Product Title {{ i }}</h6>
                         <div class="price-wrap mb-0">
                           <h4 class="price-new">$19.99</h4>
                         </div>
                       </div>
                     </div>
                   {%- endfor -%}
                 {%- endif -%}
               </div>
             </div>
           </div>
         {%- endfor -%}
       </div>
       <div class="sw-dot-default tf-sw-pagination"></div>
     </div>
   </div>
 </section>
 
