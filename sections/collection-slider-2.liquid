      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "space_tablet",
      "label": "Spacing Tablet",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "space_mobile",
      "label": "Spacing Mobile",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show Pagination",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Category"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
