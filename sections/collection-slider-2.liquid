<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }
</style>

<div class="s-category section-{{ section.id }}-padding" id="section-{{ section.id }}">
  {% if section.settings.heading != blank or section.settings.description != blank %}
    <div class="sect-title text-center wow fadeInUp">
      {%- if section.settings.heading != blank -%}
        <p class="s-title h1 fw-medium mb-8">{{ section.settings.heading }}</p>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p class="s-subtitle h6">{{ section.settings.description }}</p>
      {%- endif -%}
    </div>
  {% endif %}
  <div
    dir="ltr"
    class="swiper tf-swiper wow fadeInUp"
    data-preview="{{ section.settings.slides_desktop }}"
    data-tablet="{{ section.settings.slides_tablet }}"
    data-mobile-sm="{{ section.settings.slides_mobile }}"
    data-mobile="2"
    data-space-lg="{{ section.settings.space_desktop }}"
    data-space-md="{{ section.settings.space_tablet }}"
    data-space="{{ section.settings.space_mobile }}"
    data-pagination="2"
    data-pagination-sm="2"
    data-pagination-md="3"
    data-pagination-lg="5"
  >
    <div class="swiper-wrapper">
      {%- for block in section.blocks -%}
        {%- liquid
          assign collection = block.settings.collection
          assign slider_image = block.settings.image | default: collection.featured_image
          assign slider_title = collection.title
          assign slider_link = collection.url | default: '#'
        -%}
        <div class="swiper-slide" {{ block.shopify_attributes }}>
          <div class="box-image_category hover-img">
            <a href="{{ slider_link }}" class="box-image_image img-style">
              {%- if slider_image != blank -%}
                {{
                  slider_image
                  | image_url: width: 800
                  | image_tag: class: 'lazyload', loading: 'lazy', alt: slider_title
                }}
              {%- else -%}
                {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </a>
            <div class="box-image_content">
              <a href="{{ slider_link }}" class="tf-btn btn-white animate-btn animate-dark">
                <span class="h5 fw-medium">{{ slider_title | default: 'Collection' }}</span>
              </a>
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.show_pagination -%}
      <div class="sw-dot-default tf-sw-pagination"></div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection Slider 2",
  "settings": [
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
