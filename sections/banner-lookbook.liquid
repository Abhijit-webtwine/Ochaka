{% comment %}
  Banner Lookbook Section
  - Displays products as pins over a banner image
  - Support bundle add to cart
{% endcomment %}

<style>
  {% if section.settings.product_set_bg_color != blank %}
    .section-{{ section.id }}-banner-lookbook .banner-product-set {
      background-color: {{ section.settings.product_set_bg_color }};
    }
  {% endif %}

  {% if section.settings.individual_button_bg_color != blank %}
    .section-{{ section.id }}-banner-lookbook .banner-lookbook-individual-btn {
      background-color: {{ section.settings.individual_button_bg_color }};
      {% if section.settings.individual_button_text_color != blank %}
        color: {{ section.settings.individual_button_text_color }};
      {% endif %}
    }
  {% endif %}

  {% if section.settings.set_button_bg_color != blank %}
    .section-{{ section.id }}-banner-lookbook .banner-lookbook-set-btn {
      background-color: {{ section.settings.set_button_bg_color }};
      {% if section.settings.set_button_text_color != blank %}
        color: {{ section.settings.set_button_text_color }};
      {% endif %}
    }
  {% endif %}

  .section-{{ section.id }}-banner-lookbook,
  .section-{{ section.id }}-banner-lookbook .name-product,
  .section-{{ section.id }}-banner-lookbook .banner-product-set .price-new,
  .section-{{ section.id }}-banner-lookbook .total-price,
  .section-{{ section.id }}-banner-lookbook .set_title {
    color: {{ section.settings.text_color }};
  }

  .section-{{ section.id }}-banner-lookbook .s-subtitle {
     opacity: {{ section.settings.subtitle_opacity }};
     color: {{ section.settings.text_color }};
  }

  .section-{{ section.id }}-banner-lookbook .tag-product {
     opacity: {{ section.settings.product_type_opacity }};
     color: {{ section.settings.text_color }};
  }


  .section-{{ section.id }}-banner-lookbook .product-inventory,
  .section-{{ section.id }}-banner-lookbook .text-third {
    color: {{ section.settings.stock_status_color }};
  }

  .section-{{ section.id }}-banner-lookbook .product-badge_item {
    background-color: {{ section.settings.badge_bg_color }};
    color: {{ section.settings.badge_text_color }};
  }
</style>

<section class="sect-lookbook tf-lookbook-hover section-{{ section.id }}-banner-lookbook">
  <div class="banner-lookbook">
    {% if section.settings.image != blank %}
      {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'lazyload img-banner', loading: 'lazy' }}
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg img-banner' }}
    {% endif %}

    {% for block in section.blocks %}
      {% if block.type == 'lookbook_item' %}
        {% assign product = block.settings.product %}
        <div class="lookbook-item" style="top: {{ block.settings.top }}%; left: {{ block.settings.left }}%;" {{ block.shopify_attributes }}>
          <div class="dropdown dropup-center dropdown-custom dropstart">
            <div role="dialog" class="tf-pin-btn bundle-pin-item swiper-button" data-slide="0" id="pin{{ forloop.index }}"
              data-bs-toggle="dropdown" aria-expanded="false">
              <span></span>
            </div>
            <div class="dropdown-menu p-0">
              <div class="lookbook-product style-row">
                {% if product != blank %}
                  <div class="content">
                    {% if settings.show_type %}
                      <span class="tag">{{ product.type }}</span>
                    {% endif %}
                    <{{ section.settings.product_title_size }} class="name-prd">
                      <a href="{{ product.url }}" class="link">
                        {{ product.title }}
                      </a>
                    </{{ section.settings.product_title_size }}>
                    <div class="price-wrap">
                      <span class="price-new h6">{{ product.price | money_without_trailing_zeros }}</span>
                      <span class="text-third h6">
                        {% if product.available %}
                          {{ 'products.product.inventory.in_stock_label' | t }}
                        {% else %}
                          {{ 'products.product.sold_out' | t }}
                        {% endif %}
                      </span>
                    </div>
                  </div>
                  <a href="{{ product.url }}" class="image">
                    {{ product.featured_image | image_url: width: 300 | image_tag: alt: product.title }}
                  </a>
                {% else %}
                  <div class="content">
                    <span class="tag">Category</span>
                    <{{ section.settings.product_title_size }} class="name-prd"><a href="#" class="link">Product Title</a></{{ section.settings.product_title_size }}>
                    <div class="price-wrap">
                      <span class="price-new h6">$99</span>
                    </div>
                  </div>
                  <div class="image">
                    {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="banner-product-set">
    <div class="banner_content">
      {% if section.settings.badge_text != blank or section.settings.badge_highlight != blank %}
        <p class="product-badge_item h6 sale {% if section.settings.badge_rounded %}style-2 {% endif %}"> {{ section.settings.badge_text }} <span class="fw-bold"> {{ section.settings.badge_highlight }}</span></p>
      {% endif %}
      <div class="sect-title">
        {% liquid
          assign subtitle = false
          if section.settings.subheading != blank
            assign subtitle = true
          endif
        %}

        {% render 'title',
          class: 'set_title text-xxl-nowrap',
          title: section.settings.heading,
          subtitle: subtitle,
          large_title: section.settings.heading_style,
          heading_weight: section.settings.heading_weight,
        %}

        {% if section.settings.subheading != blank %}
          <p class="s-subtitle h6">{{ section.settings.subheading | escape }}</p>
        {% endif %}
      </div>

      <ul class="list-ver w-100 bundle-hover-wrap">
        {% assign total_price = 0 %}
        {% assign set_variant_ids = "" %}
        {% assign first_product = nil %}
        {% for block in section.blocks %}
          {% if block.type == 'lookbook_item' %}
            {% assign product = block.settings.product %}
            {% if first_product == nil and product != blank %}
              {% assign first_product = product %}
            {% endif %}
            <li>
              <div class="card-product product-style_list-mini bundle-hover-item pin{{ forloop.index }}">
                <div class="card-product_wrapper {{ settings.card_corners }}">
                  {% if product != blank %}
                    <a href="{{ product.url }}" class="product-img">
                      {{ product.featured_image | image_url: width: 200 | image_tag: class: 'lazyload img-product', alt: product.title }}
                    </a>
                  {% else %}
                    <div class="product-img">
                      {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                    </div>
                  {% endif %}
                </div>
                <div class="card-product_info">
                  {% if product != blank %}
                    {% if settings.show_type %}
                      <p class="tag-product text-small">{{ product.type }}</p>
                    {% endif %}
                    <h6>
                      <{{ section.settings.product_title_size }}>
                        <a href="{{ product.url }}" class="name-product link">{{ product.title }}</a>
                      </{{ section.settings.product_title_size }}>
                    </h6>
                    <div class="price-wrap">
                      <span class="price-new h6 fw-semibold">{{ product.price | money_without_trailing_zeros }}</span>
                      <span class="h6 product-inventory">
                        {% if product.available %}
                          {{ 'products.product.inventory.in_stock_label' | t }}
                        {% else %}
                          {{ 'products.product.sold_out' | t }}
                        {% endif %}
                      </span>
                    </div>
                    {% assign total_price = total_price | plus: product.price %}
                    {% assign set_variant_ids = set_variant_ids | append: product.selected_or_first_available_variant.id | append: "," %}
                  {% else %}
                    <p class="tag-product text-small">Category</p>
                    <{{ section.settings.product_title_size }}><a href="#" class="name-product link">Product Title</a></{{ section.settings.product_title_size }}>
                    <div class="price-wrap">
                      <span class="price-new h6 fw-semibold">$0</span>
                    </div>
                  {% endif %}
                </div>
                {% if product != blank %}
                  <product-form>
                    {%- assign individual_form_id = 'product-form-' | append: section.id | append: '-' | append: block.id -%}
                    {%- form 'product', product, id: individual_form_id, data-type: 'add-to-cart-form' -%}
                      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                      <button
                        type="submit"
                        name="add"
                        class="tf-btn animate-btn type-small fw-semibold w-100 banner-lookbook-individual-btn"
                      >
                        {{ 'products.product.add_to_cart' | t }}
                        <i class="icon icon-arrow-right d-none d-sm-block"></i>
                      </button>
                    {%- endform -%}
                  </product-form>
                {% endif %}
              </div>
            </li>
            {% unless forloop.last %}
              <li class="br-line"></li>
            {% endunless %}
          {% endif %}
        {% endfor %}
      </ul>
      {% if first_product != blank %}
        <product-form-multi-add class="w-100">
          {%- assign product_form_id = 'product-form' | append: section.id -%}
          {%- form 'product', first_product, id: product_form_id, data-type: 'add-to-cart-form' -%}
            {% assign variant_ids = set_variant_ids | split: "," %}
            {% for v_id in variant_ids %}
              {% if v_id != blank %}
                <input type="hidden" name="id" value="{{ v_id }}">
              {% endif %}
            {% endfor %}
            <div class="w-100 text-center">
              <p class="h4 total-price">Total price: <span class="fw-bold">{{ total_price | money }}</span></p>
              <button
                type="submit"
                name="add"
                class="tf-btn w-100 banner-lookbook-set-btn"
              >
                {{ section.settings.button_text | default: 'ADD SET TO CART' }}
                <i class="icon icon-shopping-cart-simple"></i>
              </button>
            </div>
          {% endform %}
        </product-form-multi-add>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Banner Lookbook",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Set Dress"
    },
    {
      "type": "text",
      "id": "badge_highlight",
      "label": "Badge Highlight",
      "default": "SALE OFF 15%"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Long Fitted Halter Neck Dress"
    },
    {
      "type": "select",
      "id": "heading_style",
      "label": "Heading Style",
      "options": [
        {
          "value": "true",
          "label": "Large"
        },
        {
          "value": "false",
          "label": "Small"
        }
      ],
      "default": "true"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Weight",
      "options": [
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "none",
          "label": "None"
        }
      ],
      "default": "none"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Up to 50% off Lorem ipsum dolor sit amet, consectetur adipiscing elit"
    },
    {
      "type": "color",
      "id": "product_set_bg_color",
      "label": "Product Set Background"
    },
    {
      "type": "color",
      "id": "individual_button_text_color",
      "label": "Individual Button Text Color"
    },
    {
      "type": "color",
      "id": "set_button_text_color",
      "label": "Set Button Text Color"
    },
    {
      "type": "color",
      "id": "individual_button_bg_color",
      "label": "Individual Button Background"
    },
    {
      "type": "color",
      "id": "set_button_bg_color",
      "label": "Set Button Background"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Global Text Color",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "subtitle_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Subtitle Opacity",
      "default": 1
    },
    {
      "type": "range",
      "id": "product_type_opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "label": "Product Type Opacity",
      "default": 1
    },
    {
      "type": "checkbox",
      "id": "badge_rounded",
      "label": "Badge Rounded Corners",
      "default": true
    },
    {
      "type": "color",
      "id": "stock_status_color",
      "label": "Stock Status Color",
      "default": "#22c55e"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge Background Color",
      "default": "#fde68a"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge Text Color",
      "default": "#92400e"
    },
    {
      "type": "select",
      "id": "product_title_size",
      "label": "Product Title Size",
      "options": [
        { "value": "h6", "label": "Small" },
        { "value": "h5", "label": "Medium" }
      ],
      "default": "h6"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "ADD SET TO CART"
    }
  ],
  "blocks": [
    {
      "type": "lookbook_item",
      "name": "Product Pin",
      "limit": 5,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "range",
          "id": "top",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Vertical Position (Top)",
          "default": 50
        },
        {
          "type": "range",
          "id": "left",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Horizontal Position (Left)",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Lookbook",
      "blocks": [
        {
          "type": "lookbook_item",
          "settings": {
            "top": 20,
            "left": 30
          }
        },
        {
          "type": "lookbook_item",
          "settings": {
            "top": 60,
            "left": 70
          }
        }
      ]
    }
  ]
}
{% endschema %}
