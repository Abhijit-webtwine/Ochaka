{%- if template contains 'product' -%}
  <section class="themesFlat" id="buy-the-look-{{ section.id }}" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
    <div class="container">
      {%- if section.settings.heading != blank -%}
        <h2 class="sect-title fw-normal">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      <div class="tab-buy-wrap flat-animate-tab">
        {%- if section.blocks.size > 0 -%}
          <ul class="tab-buy_list" role="tablist">
            {%- for block in section.blocks -%}
              {%- assign product = block.settings.product -%}
              {%- if product != blank -%}
                <li class="nav-tab-item" role="presentation" {{ block.shopify_attributes }}>
                  <a href="#look-{{ block.id }}" data-bs-toggle="tab" class="tf-btn-tab {% if forloop.first %}active{% endif %}">
                    {%- assign tab_image = block.settings.custom_image | default: product.featured_image -%}
                    {%- if tab_image != blank -%}
                      <img class="lazyload" 
                           src="{{ tab_image | image_url: width: 100 }}" 
                           data-src="{{ tab_image | image_url: width: 200 }}" 
                           alt="{{ tab_image.alt | escape }}"
                           width="{{ tab_image.width }}"
                           height="{{ tab_image.height }}">
                    {%- endif -%}
                  </a>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>

          <div class="tab-content">
            {%- for block in section.blocks -%}
              {%- assign product = block.settings.product -%}
              {%- if product != blank -%}
                <div class="tab-pane {% if forloop.first %}active show{% endif %}" id="look-{{ block.id }}" role="tabpanel">
                  <div class="wg-buy-look">
                    <div class="buy_image">
                      {%- assign main_image = block.settings.custom_image | default: product.featured_image -%}
                      {%- if main_image != blank -%}
                        <img class="lazyload" 
                             src="{{ main_image | image_url: width: 500 }}" 
                             data-src="{{ main_image | image_url: width: 800 }}" 
                             alt="{{ main_image.alt | escape }}"
                             width="{{ main_image.width }}"
                             height="{{ main_image.height }}">
                      {%- endif -%}
                    </div>
                    <div class="buy_content">
                      <div class="prd-head">
                        <a href="{{ product.url }}" class="link name h4">{{ product.title }}</a>
                        <p class="price h5 text-black">{{ product.price | money }}</p>
                      </div>

                      {%- assign product_form_id = 'product-form-' | append: block.id -%}
                      {%- if product.variants.size > 1 -%}
                        <variant-selects class="no-js-hidden" data-section="{{ block.id }}" data-url="{{ product.url }}" data-update-url="false">
                          {%- for option in product.options_with_values -%}
                            <div class="prd-size mb-20" style="margin-bottom: 20px;">
                              <h4 class="title fw-semibold">{{ option.name }}</h4>
                              <div class="tf-select style-border">
                                <select class="h6" name="options[{{ option.name | escape }}]">
                                  {%- for value in option.values -%}
                                    <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
                                      {{ value }}
                                    </option>
                                  {%- endfor -%}
                                </select>
                              </div>
                            </div>
                          {%- endfor -%}
                          <script type="application/json">
                            {{ product.variants | json }}
                          </script>
                        </variant-selects>
                      {%- endif -%}

                      <div class="prd-action mt-30" style="margin-top: 30px;">
                        <product-form class="w-100">
                          {%- form 'product', product, id: product_form_id, class: 'w-100', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                            <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                            <button type="submit" name="add" class="tf-btn style-line w-100">
                              Add to cart
                              <i class="icon icon-shopping-cart-simple"></i>
                            </button>
                          {%- endform -%}
                        </product-form>
                        <a href="{{ product.url }}" class="tf-btn-line mt-10" style="margin-top: 10px;">
                          <span class="h6 text-normal">See details</span>
                        </a>
                      </div>
                    </div>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

{% schema %}
{
  "name": "Buy the Look",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Buy the look"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Buy the Look",
      "blocks": [
        {
          "type": "product"
        },
        {
          "type": "product"
        }
      ]
    }
  ]
}
{% endschema %}