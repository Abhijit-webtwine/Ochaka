<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }
</style>

<section class="section-{{ section.id }}-padding">
  <div class="container">
    {% if section.settings.header_layout == 'with_subtitle' %}
      {% if section.settings.title != blank or section.settings.subtitle != blank %}
        <div class="sect-title {% if section.settings.subtitle == blank %}justify-content-center{% endif %} {{ section.settings.header_spacing }} text-center wow fadeInUp">
          {% liquid
            assign subtitle = false
            if section.settings.subtitle != blank
              assign subtitle = true
            endif
          %}

          {% render 'title',
            class: 's-title',
            title: section.settings.title,
            subtitle: subtitle,
            large_title: section.settings.heading_style,
            heading_weight: section.settings.heading_weight,
          %}

          {% if section.settings.subtitle != blank %}
            <p class="s-subtitle h6">{{ section.settings.subtitle | escape }}</p>
          {% endif %}
        </div>
      {% endif %}
    {% endif %}

    {% if section.settings.header_layout == 'with_button' %}
      <div class="sect-title type-4 wow fadeInUp">
        {% liquid
          assign subtitle = false
          if section.settings.subtitle != blank
            assign subtitle = true
          endif
        %}

        {% render 'title',
          class: 's-title',
          title: section.settings.title,
          subtitle: false,
          large_title: section.settings.heading_style,
          heading_weight: section.settings.heading_weight,
        %}
        {% if section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="tf-btn-line">
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.header_layout == 'with_button_and_icon' %}
      <div class="sect-title type-3 type-2 wow fadeInUp">
        <h2 class="s-title type-semibold text-nowrap">{{ section.settings.title }}</h2>
        {% if section.settings.button_link != blank %}
          <a href="{{ section.settings.button_link }}" class="tf-btn-icon h6 fw-medium text-nowrap">
            {{ section.settings.button_text }}
            <i class="icon icon-caret-circle-right"></i>
          </a>
        {% endif %}
      </div>
    {% endif %}

    {% assign classes = "" %}
    {% if section.settings.show_seperator %}
      {% assign classes = "swiper-medical" %}
    {% endif %}

    {% render 'products-swiper',
      collection_ref: section.settings.collection.handle,
      products_limit: section.settings.products_limit,
      grid_rows: section.settings.grid_rows,
      slides_desktop: section.settings.slides_desktop,
      slides_tablet: section.settings.slides_tablet,
      slides_mobile: section.settings.slides_mobile,
      countdown_size: section.settings.countdown_size,
      space_desktop: section.settings.space_desktop,
      space_tablet: section.settings.space_tablet,
      space_mobile: section.settings.space_mobile,
      show_stock: section.settings.show_stock,
      stock_position: section.settings.stock_position,
      classes: classes
    %}
  </div>
</section>

{% schema %}
{
  "name": "Product Swiper",
  "settings": [
    {
      "type": "select",
      "id": "header_layout",
      "label": "Header Layout",
      "options": [
        {
          "value": "with_subtitle",
          "label": "With Subtitle"
        },
        {
          "value": "with_button",
          "label": "With Button"
        },
        {
          "value": "with_button_and_icon",
          "label": "With Button and Icon"
        }
      ],
      "default": "with_subtitle"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Best Seller"
    },
    {
      "type": "select",
      "id": "heading_style",
      "label": "Heading Style",
      "options": [
        {
          "value": "true",
          "label": "Large"
        },
        {
          "value": "false",
          "label": "Small"
        }
      ],
      "default": "true"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Weight",
      "options": [
        {
          "value": "normal",
          "label": "Normal"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "none",
          "label": "None"
        }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "header_spacing",
      "label": "Header Spacing",
      "options": [
        {
          "value": "type-4",
          "label": "Default"
        },
        {
          "value": "",
          "label": "Extended Space"
        }
      ],
      "default": ""
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Up to 50% off Lorem ipsum dolor sit amet, consectetur adipiscing elit",
      "visible_if": "{{ section.settings.header_layout == 'with_subtitle' }}"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "visible_if": "{{ section.settings.header_layout == 'with_button' or section.settings.header_layout == 'with_button_and_icon' }}"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "visible_if": "{{ section.settings.header_layout == 'with_button' or section.settings.header_layout == 'with_button_and_icon' }}",
      "default": "Shop Now"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Products Limit"
    },
    {
      "type": "select",
      "id": "grid_rows",
      "label": "Grid Rows",
      "options": [
        { "value": "1", "label": "1 Row" },
        { "value": "2", "label": "2 Rows" }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "countdown_size",
      "label": "Countdown Size",
      "options": [
        { "value": "type-2", "label": "Small" },
        { "value": "", "label": "Medium" }
      ],
      "default": ""
    },
    {
      "type": "checkbox",
      "id": "show_stock",
      "default": true,
      "label": "Show Stock"
    },
    {
      "type": "checkbox",
      "id": "show_seperator",
      "default": false,
      "label": "Show Seperator"
    },
    {
      "type": "select",
      "id": "stock_position",
      "label": "Stock Position",
      "options": [
        {
          "value": "above_price",
          "label": "Above Price"
        },
        {
          "value": "below_price",
          "label": "Below Price"
        }
      ],
      "default": "above_price"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Slides Desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "slides_tablet",
      "label": "Slides Tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "Slides Mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Slider Spacing"
    },
    {
      "type": "range",
      "id": "space_desktop",
      "label": "Spacing Desktop",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 48
    },
    {
      "type": "range",
      "id": "space_tablet",
      "label": "Spacing Tablet",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 34
    },
    {
      "type": "range",
      "id": "space_mobile",
      "label": "Spacing Mobile",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 12
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "header",
      "content": "Tablet padding"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Product Swiper"
    }
  ]
}
{% endschema %}
