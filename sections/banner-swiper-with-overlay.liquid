{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  {%- for block in section.blocks -%}
    #block-{{ block.id }} .tf-btn-line {
      color: {{ block.settings.btn_color }};
      background: linear-gradient(to right, var(--primary) 50%, {{ block.settings.btn_color }} 50%);
      background-size: 200% 100%;
      background-position: right;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    #block-{{ block.id }} .tf-btn-line::after {
      background-color: {{ block.settings.btn_color }};
    }
  {%- endfor -%}
{%- endstyle -%}

<div class="s-collection px-0 section-{{ section.id }}-padding">
  <div class="container">
    <div
      dir="ltr"
      class="swiper tf-swiper wow fadeInUp"
      data-preview="{{ section.settings.slides_desktop }}"
      data-tablet="{{ section.settings.slides_tablet }}"
      data-mobile-sm="{{ section.settings.slides_mobile }}"
      data-mobile="1"
      data-pagination="1"
      data-space-lg="{{ section.settings.space_desktop }}"
      data-space-md="{{ section.settings.space_tablet }}"
      data-space="{{ section.settings.space_mobile }}"
      data-pagination-sm="1"
      data-pagination-md="2"
      data-pagination-lg="3"
    >
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          <div id="block-{{ block.id }}" class="swiper-slide" {{ block.shopify_attributes }}>
            <div class="box-image_V06 type-space-2 has-overlay {{ block.settings.overlay_class }} hover-img rounded-0">
              {%- if block.settings.badge_text != blank -%}
                <ul class="product-badge_list">
                  <li
                    class="product-badge_item fw-normal h6 rounded-0"
                    style="background-color: {{ block.settings.badge_bg_color }}; color: {{ block.settings.badge_text_color }};"
                  >
                    {{ block.settings.badge_text }}
                  </li>
                </ul>
              {%- endif -%}
              <a href="{{ block.settings.link | default: '#' }}" class="box-image_image img-style">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 1000 }}"
                    data-src="{{ block.settings.image | image_url: width: 1000 }}"
                    alt="{{ block.settings.image.alt | default: 'Banner' }}"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                    class="lazyload"
                  >
                {%- else -%}
                  {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </a>
              <div class="box-image_content">
                {%- if block.settings.title != blank -%}
                  <h4 class="title">
                    <a
                      href="{{ block.settings.link | default: '#' }}"
                      class="link"
                      style="color: {{ block.settings.title_color }};"
                    >
                      {{ block.settings.title | newline_to_br }}
                    </a>
                  </h4>
                {%- endif -%}
                {%- if block.settings.btn_text != blank -%}
                  <a
                    href="{{ block.settings.link | default: '#' }}"
                    class="tf-btn-line letter-space-0"
                  >
                    {{- block.settings.btn_text -}}
                  </a>
                {%- endif -%}
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
      <div class="sw-dot-default tf-sw-pagination"></div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Banner Swiper Overlay",
  "settings": [
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "range",
