{%- liquid
  assign form_status = false
-%}

{%- capture newsletter_form -%}
  {%- form 'customer', class: 'newsletter-form mb-24' -%}
    {%- if form.posted_successfully? or form.errors -%}
      {%- assign form_status = true -%}
    {%- endif -%}
    <input type="hidden" name="contact[tags]" value="newsletter">
    <div class="sib-form-container">
      {%- if form.errors -%}
        <div class="sib-form-message-panel error">
          <div class="sib-form-message-panel__text sib-form-message-panel__text--center">
            <svg viewBox="0 0 512 512" class="sib-icon sib-notification__icon">
              <path d="M256 40c118.621 0 216 96.075 216 216 0 119.291-96.61 216-216 216-119.244 0-216-96.562-216-216 0-119.203 96.602-216 216-216m0-32C119.043 8 8 119.083 8 256c0 136.997 111.043 248 248 248s248-111.003 248-248C504 119.083 392.957 8 256 8zm-11.49 120h22.979c6.823 0 12.274 5.682 11.99 12.5l-7 168c-.268 6.428-5.556 11.5-11.99 11.5h-8.979c-6.433 0-11.722-5.073-11.99-11.5l-7-168c-.283-6.818 5.167-12.5 11.99-12.5zM256 340c-15.464 0-28 12.536-28 28s12.536 28 28 28 28-12.536 28-28-12.536-28-28-28z" />
            </svg>
            <span class="sib-form-message-panel__inner-text">
              {{ form.errors | default_errors }}
            </span>
          </div>
        </div>
      {%- endif -%}

      {%- if form.posted_successfully? -%}
        <div class="success">
          <div class="sib-form-message-panel__text sib-form-message-panel__text--center justify-content-center">
            <svg viewBox="0 0 512 512" class="sib-icon sib-notification__icon">
              <path d="M256 8C119.033 8 8 119.033 8 256s111.033 248 248 248 248-111.033 248-248S392.967 8 256 8zm0 464c-118.664 0-216-96.055-216-216 0-118.663 96.055-216 216-216 118.664 0 216 96.055 216 216 0 118.663-96.055 216-216 216zm141.63-274.961L217.15 376.071c-4.705 4.667-12.303 4.637-16.97-.068l-85.878-86.572c-4.667-4.705-4.637-12.303.068-16.97l8.52-8.451c4.705-4.667 12.303-4.637 16.97.068l68.976 69.533 163.441-162.13c4.705-4.667 12.303-4.637 16.97.068l8.451 8.52c4.668 4.705 4.637 12.303-.068 16.97z" />
            </svg>
            <span class="sib-form-message-panel__inner-text">
              Your subscription has been successful.
            </span>
          </div>
        </div>
      {%- else -%}
        <div class="sib-input entry_block">
          <div class="entry__field">
            <input class="input style-stroke" type="email" name="contact[email]" value="{{ form.email }}" autocomplete="email" placeholder="Enter your email" required aria-required="true">
          </div>
        </div>
        <div class="sib-form-block pt-3">
          <button class="tf-btn w-100 animate-btn" type="submit" name="commit">
            <span>Subscribe Now</span>
          </button>
        </div>
      {%- endif -%}
    </div>
  {%- endform -%}

  <ul class="tf-social-icon justify-content-center w-100">
    {%- if settings.social_facebook_link != blank -%}
      <li>
        <a href="{{ settings.social_facebook_link }}" target="_blank" class="social-facebook">
          <span class="icon"><i class="icon-fb"></i></span>
        </a>
      </li>
    {%- endif -%}
    {%- if settings.social_instagram_link != blank -%}
      <li>
        <a href="{{ settings.social_instagram_link }}" target="_blank" class="social-instagram">
          <span class="icon"><i class="icon-instagram-logo"></i></span>
        </a>
      </li>
    {%- endif -%}
    {%- if settings.social_x_link != blank -%}
      <li>
        <a href="{{ settings.social_x_link }}" target="_blank" class="social-x">
          <span class="icon"><i class="icon-x"></i></span>
        </a>
      </li>
    {%- endif -%}
    {%- if settings.social_tiktok_link != blank -%}
      <li>
        <a href="{{ settings.social_tiktok_link }}" target="_blank" class="social-tiktok">
          <span class="icon"><i class="icon-tiktok"></i></span>
        </a>
      </li>
    {%- endif -%}
  </ul>
{%- endcapture -%}

{%- if section.settings.newsletter_popup_enabled -%}
  <div class="modal modalCentered fade modal-newletter auto-popup" id="newLetter" data-delay="{{ section.settings.newsletter_popup_delay | times: 1000 }}" data-form-status="{{ form_status }}">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content p-0">
        <div class="modal-heading">
          <div class="image">
            {%- if section.settings.newsletter_popup_image != blank -%}
              <img class="lazyload" 
                src="{{ section.settings.newsletter_popup_image | image_url: width: 600 }}" 
                data-src="{{ section.settings.newsletter_popup_image | image_url: width: 600 }}" 
                alt="{{ section.settings.newsletter_popup_image.alt | default: 'Newsletter' }}"
                width="{{ section.settings.newsletter_popup_image.width }}"
                height="{{ section.settings.newsletter_popup_image.height }}"
                loading="lazy">
            {%- else -%}
              {%- assign placeholder_image = 'lifestyle-1' -%}
              {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <span class="icon-close-popup" data-bs-dismiss="modal">
            <i class="icon-close"></i>
          </span>
        </div>
        <div class="modal-body">
          <p class="h6 sub-title">{{ section.settings.newsletter_popup_sub_title }}</p>
          <h3 class="fw-normal title">{{ section.settings.newsletter_popup_title }}</h3>
          
          {{ newsletter_form }}
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Newsletter Popup",
  "settings": [
    {
      "type": "checkbox",
      "id": "newsletter_popup_enabled",
      "label": "Enable Newsletter Popup",
      "default": true
    },
    {
      "type": "range",
      "id": "newsletter_popup_delay",
      "min": 1,
      "max": 60,
      "step": 1,
      "unit": "sec",
      "label": "Display Delay",
      "default": 10
    },
    {
      "type": "image_picker",
      "id": "newsletter_popup_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "newsletter_popup_sub_title",
      "label": "Sub-title",
      "default": "Subscribe to our newsletter!"
    },
    {
      "type": "textarea",
      "id": "newsletter_popup_title",
      "label": "Title",
      "default": "Receive 20% off your next order, along with exclusive offers and more!"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Popup"
    }
  ]
}
{% endschema %}
