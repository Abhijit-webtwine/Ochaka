<div class="themesFlat">
  <div class="container">
    <div class="tf-grid-layout lg-col-2">
      {% for block in section.blocks %}
        <div class="box-image_V02 type-space-3 hover-img" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link }}" class="box-image_image img-style">
            {% if block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 400
                | image_tag: class: 'lazyload', loading: 'lazy', alt: block.settings.image.alt
                | default: block.settings.title
              }}
            {% else %}
              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg w-100' }}
            {% endif %}
          </a>
          <div class="box-image_content wow fadeInUp">
            {% if block.settings.subtitle != blank %}
              <span class="sub-text h4 text-white mb-8">{{ block.settings.subtitle }}</span>
            {% endif %}
            {% if block.settings.title != blank %}
              <a href="{{ block.settings.link }}" class="title link text-display-2 fw-medium text-white">
                {{ block.settings.title }}
              </a>
            {% endif %}
            {% if block.settings.button_text != blank and block.settings.button_link != blank %}
              <a href="{{ block.settings.button_link }}" class="tf-btn btn-white animate-btn animate-dark">
                {{ block.settings.button_text }}
                <i class="icon icon-arrow-right"></i>
              </a>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Box Collection 2",
  "blocks": [
    {
      "type": "box_item",
      "name": "Box Item",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Diamond Jewelry"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Sale OFF 2%"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Box Collection 2",
      "blocks": [
        {
          "type": "box_item",
          "settings": {
            "subtitle": "Sale OFF 2%",
            "title": "Diamond Jewelry",
            "button_text": "Shop now"
          }
        },
        {
          "type": "box_item",
          "settings": {
            "subtitle": "Get our 5% OFF coupon",
            "title": "Birthstone Jewelry",
            "button_text": "Shop now"
          }
        }
      ]
    }
  ]
}
{% endschema %}
