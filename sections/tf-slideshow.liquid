{%- liquid
  assign image_ani_class = image_animation | default: ''
  assign fade_class = ''
  if enable_fade
    assign fade_class = 'fade-item'
  endif
  assign square_btn_class = ''
  if square_btn
    assign square_btn_class = 'rounded-0 px-xxl-32'
  endif
-%}

<div class="slider-wrap {{ slider_style }}">
  <div class="sld_image">
    {% if block.settings.slide_image != blank %}
      {%- liquid
        assign img = block.settings.slide_image
        assign img_width = img.width
        assign img_height = img.height
        assign aspect_ratio = img_width | times: 1.0 | divided_by: img_height
        assign display_width = 1920
        assign display_height = display_width | divided_by: aspect_ratio | round
      -%}
      <img
        srcset="
          {{ img | image_url: width: 480 }} 480w,
          {{ img | image_url: width: 768 }} 768w,
          {{ img | image_url: width: 1024 }} 1024w,
          {{ img | image_url: width: 1440 }} 1440w,
          {{ img | image_url: width: 1920 }} 1920w
        "
        sizes="(max-width: 480px) 480px, (max-width: 768px) 768px, (max-width: 1024px) 1024px, (max-width: 1440px) 1440px, 1920px"
        src="{{ img | image_url: width: 1920 }}"
        alt="{{ block.settings.slide_title | escape }}"
        class="{{ image_ani_class }}"
        width="{{ display_width }}"
        height="{{ display_height }}"
        {% if index == 0 %}
          loading="eager"
          fetchpriority="high"
        {% else %}
          loading="lazy"
        {% endif %}
        decoding="async"
      >
    {% else %}
      {% assign placeholder_index = index | modulo: 2 | plus: 1 %}
      {% assign placeholder_img = 'hero-apparel-' | append: placeholder_index %}
      {{ placeholder_img | placeholder_svg_tag }}
    {% endif %}
  </div>
  <div class="sld_content {% if slider_style == 'style-2' or slider_style == 'style-7' %}{{ block.settings.content_alignment }} {% endif %}{% if block.settings.slide_description == blank and block.settings.slide_subtitle == blank %}only-title {% endif %}">
    <div class="container">
      <div class="row">
        <div class="
          {% if slider_style == 'style-2' or slider_style == 'style-7' %}
            {% if block.settings.content_alignment contains 'text-end' %}ms-auto text-end
            {% elsif block.settings.content_alignment contains 'text-center' %}mx-auto
            {% endif %}
          {% endif %}
          {% if slider_style == 'style-2' %} col-sm-8 col-10{% endif %}"
        >
          <div class="content-sld_wrap {% if slider_style == 'style-2' or slider_style == 'style-7' %}{% if block.settings.content_alignment contains 'text-end' %}ms-sm-auto{% elsif block.settings.content_alignment contains 'text-center' %}mx-auto{% endif %}{% endif %}">
            {% if block.settings.slide_subtitle != blank %}
              <p class="sub-title_sld {{ subtitle_size }} {{ fade_class }} fade-item-1">
                {{ block.settings.slide_subtitle }}
              </p>
            {% endif %}
            {% if block.settings.slide_title != blank %}
              {% assign classes = 'title_sld text-display fade-item-2 ' | append: fade_class %}
              {% render 'title',
                class: classes,
                title: block.settings.slide_title,
                subtitle: block.settings.subtitle,
                large_title: block.settings.heading_size,
                heading_weight: block.settings.heading_weight,
              %}
            {% endif %}
            {% if block.settings.slide_description != blank %}
              <p class="sub-text_sld {{ description_size }}  {{ fade_class }} fade-item-3">
                {{ block.settings.slide_description | newline_to_br }}
              </p>
            {% endif %}
            {% if block.settings.slide_link != blank %}
              <div class="{{ fade_class }} fade-item-4">
                <a href="{{ block.settings.slide_link }}" class="tf-btn animate-btn {{ square_btn_class }}">
                  {{ block.settings.slide_button_text }}
                  <i class="icon icon-arrow-right"></i>
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>