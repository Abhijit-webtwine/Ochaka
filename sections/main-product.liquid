{{ 'drift-basic.min.css' | asset_url | stylesheet_tag }}
{{ 'photoswipe.css' | asset_url | stylesheet_tag }}
{{ 'image-compare-viewer.min.css' | asset_url | stylesheet_tag }}

<section class="flat-single-product flat-spacing-3">
  <div class="tf-main-product section-image-zoom">
    <div class="container">
      <div class="row">
        <!-- Product Images -->
        <div class="col-md-6">
          {% if section.settings.main_product_layout == 'thumb_swiper' %}
            <div class="tf-product-media-wrap sticky-top">
              <div class="product-thumbs-slider {% if section.settings.thumb_position == 'bottom' %}thumbs-bottom{% endif %}">
                {% if section.settings.thumb_position == 'left' %}
                  {% render 'main-product-thumb-swiper', product: product, direction: 'vertical', preview: 'auto' %}
                  {% render 'main-product-media-swiper', product: product %}
                {% elsif section.settings.thumb_position == 'right' %}
                  {% render 'main-product-media-swiper', product: product %}
                  {% render 'main-product-thumb-swiper', product: product, direction: 'vertical', preview: 'auto' %}
                {% elsif section.settings.thumb_position == 'bottom' %}
                  {% render 'main-product-thumb-swiper', product: product, direction: 'horizontal', preview: '5', space: '12' %}
                  {% render 'main-product-media-swiper', product: product %}
                {% endif %}
              </div>
            </div>
          {% elsif section.settings.main_product_layout == 'grid-1' or section.settings.main_product_layout == 'grid-2' or section.settings.main_product_layout == 'stack' %}
            <div class="tf-product-media-wrap sticky-top wrapper-gallery-scroll product-grid-img {% if section.settings.main_product_layout == 'grid-2' %}product-grid-img2{% elsif section.settings.main_product_layout == 'stack' %}product-grid-stacked{% endif %}">
              <div class="product-thumbs-slider">
                {% render 'main-product-thumb-swiper', product: product, direction: 'vertical', preview: '4.7', classes: 'd-md-none' %}
                {% render 'main-product-media-swiper', product: product, wrapper_classes: 'w-100' %}
              </div>
            </div>
          {% endif %}
        </div>
        <!-- /Product Images -->
        <!-- Product Info -->
        <div class="col-md-6">
          <div class="tf-product-info-wrap position-relative {% if section.settings.main_product_layout == 'grid-1' or section.settings.main_product_layout == 'grid-2' or section.settings.main_product_layout == 'stack' %}sticky-top{% endif %}">
            <div class="tf-zoom-main sticky-top"></div>
            <div class="tf-product-info-list other-image-zoom">
              {% if section.settings.show_brand %}
                <div class="tf-product-info-brand">
                  <span class="text-large">Brand:</span>
                  <a href="#" class="h6 text-primary">{{ product.vendor }}</a>
                </div>
              {% endif %}
              
              <h2 class="product-info-name">{{ product.title }}</h2>

              {% comment %} price and countdown moved to blocks {% endcomment %}

              {%- liquid
                assign product_form_id = 'product-form-' | append: section.id
                assign has_group_product = false 
                for block in section.blocks
                  if block.type == 'group_product' and product.metafields.custom.group_product.value != blank
                    assign has_group_product = true
                    break
                  endif
                endfor
              -%}
              {% for block in section.blocks %}
                {% case block.type %}
                  {% when 'rating_atc_count' %}
                    <div class="product-info-meta">
                      {% if block.settings.show_rating %}
                        {% render 'rating', product: product %}
                      {% endif %}

                      {% comment %} add to cart count {% endcomment %}
                      <div class="people-add text-primary">
                        {% if block.settings.show_atc_count %}
                          <add-to-cart-count 
                            min="{{ settings.min_atc_count }}" 
                            max="{{ settings.max_atc_count }}">
                            <div class="add-to-cart-count-container d-flex align-items-center gap-1 w-100">
                              <i class="icon icon-shopping-cart-simple"></i>
                              <p id="view-count" class="visitor-count h6">
                                <span class="vc-number"></span> people just added this product to their cart
                              </p>
                            </div>
                          </add-to-cart-count>
                        {% endif %}
                      </div>
                    </div>
                  {% when 'price_countdown' %}
                    {%- liquid
                      assign layout_type = block.settings.layout_type 
                      assign price_h = block.settings.price_size | default: 'h2'
                      assign compare_price_h = block.settings.compare_price_size | default: 'h6'
                    -%}
                    <div class="tf-product-heading {% if layout_type == 'price_visitor' or layout_type == 'price_rating' %}gap-32 align-items-center justify-content-start {% endif %} {% if block.settings.show_border_top %}border-top-0{% endif %} {% if block.settings.show_border_bottom %}border-bottom-0{% endif %}">
                      <div id="price-{{ section.id }}" class="product-info-price price-wrap {% if layout_type == 'price_rating' %}gap-12{% endif %}">
                        <span class="price-new price-on-sale {{ price_h }} fw-4 {% if layout_type == 'price_rating' %}m-0{% endif %}">{{ product.selected_or_first_available_variant.price | money }}</span>
                        {% if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price %}
                          {% if block.settings.show_compare_price %}
                            <span class="price-old {% if layout_type == 'price_rating' %}compare-at-price{% endif %} {{ compare_price_h }} fw-4">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
                          {% endif %}

                          {% if block.settings.show_discount %}
                            <p class="badges-on-sale h6 fw-semibold">
                              <span class="number-sale" data-person-sale="29">
                                -{{ product.selected_or_first_available_variant.compare_at_price
                                  | minus: product.selected_or_first_available_variant.price
                                  | times: 100
                                  | divided_by: product.selected_or_first_available_variant.compare_at_price
                                }} %
                              </span>
                            </p>
                          {% endif %}
                        {% endif %}
                      </div>
                      {% comment %} countdown {% endcomment %}
                      {% if layout_type == 'price_countdown' %}
                        {% if settings.enable_countdown and product.metafields.custom.countdown_timer.value != blank %}
                          <div class="tf-product-info-countdown">
                            <div class="countdown-title">
                              <h5>Hurry up</h5>
                              <p class="text-main">offer ends in:</p>
                            </div>
                            <div class="tf-countdown style-1">
                              <countdown-timer data-date="{{ product.metafields.custom.countdown_timer.value }}" data-layout="left"></countdown-timer>
                            </div>
                          </div>
                        {% endif %}
                      {% elsif layout_type == 'price_visitor' %}
                        <add-to-cart-count 
                          min="{{ block.settings.min_visitor_count }}" 
                          max="{{ block.settings.max_visitor_count }}">
                          <div class="tf-product-info-liveview mb-0">
                            <div class="liveview-count size-40">
                              <span class="count fw-6 h6 vc-number"></span>
                            </div>
                            <p class="fw-6 h6">People are viewing this right now</p>
                          </div>
                        </add-to-cart-count>
                      {% elsif layout_type == 'price_rating' %}
                        {% if block.settings.show_rating %}
                          {% render 'rating', product: product, layout: 'svg' %}
                        {% endif %}
                      {% endif %}
                    </div>
                  {% when 'additional_info' %}
                    {% if product.metafields.custom.additional_information.value != blank %}
                      {{ product.metafields.custom.additional_information.value }}
                    {% endif %}
                  {% when 'visitor_count' %}
                    {% comment %} visitor count {% endcomment %}
                      <visitor-count 
                        min="{{ block.settings.min_visitor_count }}" 
                        max="{{ block.settings.max_visitor_count }}">
                        <div class="tf-product-info-liveview">
                          <div class="liveview-count">
                            <i class="icon icon-view"></i>
                            <span class="count fw-6 h6 vc-number"></span>
                          </div>
                          <p class="fw-6 h6">People are viewing this right now</p>
                          </div>
                      </visitor-count>

                  {% when 'visitor_count_2' %}
                    {% comment %} visitor count 2 {% endcomment %}
                    <add-to-cart-count 
                      min="{{ block.settings.min_visitor_count }}" 
                      max="{{ block.settings.max_visitor_count }}">
                      <div class="tf-product-info-liveview">
                        <div class="liveview-count size-40">
                          <span class="count fw-6 h6 vc-number"></span>
                        </div>
                        <p class="fw-6 h6">People are viewing this right now</p>
                      </div>
                    </add-to-cart-count>

                  {% when 'inventory_status' %}
                    <div class="available text mb-12">
                      {%- if product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                        Available: <span class="number text-black fw-7">{{ product.selected_or_first_available_variant.inventory_quantity }}</span>
                      {%- else -%}
                        <span class="number text-black fw-7">{{ 'products.product.sold_out' | t | default: 'Sold Out' }}</span>
                      {%- endif -%}
                    </div>

                  {% when 'back_in_stock' %}
                    {% unless product.selected_or_first_available_variant.available %}
                      {% form 'contact', id: 'back-in-stock-form', class: 'form-out-stock' %}
                        {% if form.posted_successfully? %}
                          <p class="h6 bg-green-light p-3 rounded">We'll notify you as soon as this product is back in stock!</p>
                        {% else %}
                          <h4 class="box-title-out-stock">
                            <i class="icon icon-envelope"></i>
                            Email when stock available
                          </h4>
                          <div class="mb-3">
                            <input class="tf-field-input tf-input" id="bis-name" placeholder="Your name" type="text" name="contact[name]" required>
                          </div>
                          <div class="mb-3">
                            <input class="tf-field-input tf-input" id="bis-email" placeholder="Email address" type="email" name="contact[email]" required>
                          </div>
                          <input type="hidden" name="contact[body]" value="Back in stock notification request for {{ product.title }} - {{ product.selected_or_first_available_variant.title }}">
                          <button type="submit" class="tf-btn animate-btn">Subscribe now</button>
                        {% endif %}
                      {% endform %}
                    {% endunless %}

                  {% when 'variant_picker' %}
                    {% render 'product-variant-picker', section: section, product: product, product_form_id: product_form_id, block: block %}

                  {% when 'option_customizer' %}
                    <div class="tf-product-property"> 
                      <div class="item personalize"> 
                        <input class="pdp-customizer-input bg-white" placeholder="Personalize" type="text" name="properties[Personalize]" form="{{ product_form_id }}"> 
                      </div> 
                      <div class="item desc"> 
                        <input class="pdp-customizer-input bg-white" placeholder="Write your text" type="text" name="properties[Description]" form="{{ product_form_id }}"> 
                      </div> 
                    </div> 

                  {% when 'countdown' %}
                    {%- liquid
                        assign end_date = product.metafields.custom.countdown_timer.value
                        if block.settings.end_date != blank
                          assign end_date = block.settings.end_date | append: 'T' | append: block.settings.end_time | append: ':00'
                        endif
                    -%}
                    {% if block.settings.show_timer and end_date != blank %}
                    <div class="tf-product-info-countdown type-box">
                        <div class="countdown-title">
                            {% render 'icon-timer' %}
                            <h5>{{ block.settings.title }}</h5>
                        </div>
                        <div class="tf-countdown style-1">
                            <countdown-timer class="cd-has-zero" data-date="{{ end_date }}" data-labels="{{ block.settings.labels }}" data-layout="left"></countdown-timer>
                        </div>
                    </div>
                    {% endif %}
                {% endcase %}
              {% endfor %}

              {%- unless has_group_product -%}
              <product-form>
                {%- form 'product', product, id: product_form_id, data-type: 'add-to-cart-form', class: 'w-100 position-static' -%}
                  <div class="tf-product-total-quantity">
                    <div class="group-btn">

                      {% comment %} Quantity Input {% endcomment %}
                      {% render 'quantity-input', product: product, product_form_id: product_form_id %}

                      {% comment %} Add to Cart Button {% endcomment %}

                          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" disabled="disabled"/>
                          <button
                            type="submit"
                            name="add"
                            class="tf-btn animate-btn btn-add-to-cart"          
                            {%- if product.selected_or_first_available_variant.available == false %} disabled="disabled"{% endif -%}
                          >
                            <i class="icon icon-shopping-cart-simple"></i>
                            {{ 'products.product.add_to_cart' | t }}
                          </button>


                      {% if settings.wishlist_enabled %}
                        {% render 'icon-wishlist' %}
                      {% endif %}
                      
                      {% if settings.compare_enabled %}
                        {% render 'icon-compare' %}
                      {% endif %}
                    </div>
                    {% comment %} Checkout Button {% endcomment %}
                    <div class="shopify-payment-btn">
                      {{ form | payment_button }}
                    </div>
                  </div>
                {% endform %}
              </product-form>
              {%- endunless -%}

              <div class="tf-product-extra-link">
                <a href="#sizeChart" data-bs-toggle="modal" class="product-extra-icon link">
                  <i class="icon icon-swatches"></i>Size Guide
                </a>
                <a href="#askQuestion" data-bs-toggle="modal" class="product-extra-icon link">
                  <i class="icon icon-ques"></i>Ask a question
                </a>
                <a href="#shipAndDelivery" data-bs-toggle="modal" class="product-extra-icon link">
                  <i class="icon icon-truck"></i>Delivery & Return
                </a>
                <a href="#shareWith" data-bs-toggle="modal" class="product-extra-icon link">
                  <i class="icon icon-share"></i>Share
                </a>
              </div>

              {% comment %} Buy X get Y {% endcomment %}
              {% for block in section.blocks %}
                {% case block.type %}
                  {% when 'buyX-getY' %}
                    {% assign variant_list = product.metafields.custom.buy_x_get_y.value %}
                    {% if variant_list.size > 0 %}
                      {% assign product_form_id = 'product-form-buy-x' | append: section.id %}
                      <product-form-multi-add>
                        {%- form 'product', product, id: product_form_id, data-type: 'add-to-cart-form', class: 'w-100 form-buyX-getY position-static' -%}
                          <div class="buyX-getY-wrap">
                            {% for variant in variant_list %}
                              {% assign current_variant_image = variant.image | default: variant.product.featured_image %}

                              <div class="volume-discount-thumbnail-item p-0 border-0 flex-grow-1">
                                <input type="hidden" value="{{ variant.id }}" name="id">
                                <div class="image-box type-1">
                                  <img class="lazyload" data-src="{{ current_variant_image | image_url }}"
                                    src="{{ current_variant_image | image_url }}" alt="{{ current_variant_image.alt | escape }}"
                                    width="{{ current_variant_image.width }}"
                                    height="{{ current_variant_image.height }}">

                                  {% assign savings = 'savings-' | append: forloop.index %}
                                  <div class="tags-save h6">
                                    {% unless forloop.first %}
                                      {% if block.settings.show_gift_icon %}
                                        {% render '_icon-gift' %}
                                      {% endif %}
                                    {% endunless %}
                                    {{ block.settings[savings] }}
                                  </div>

                                </div>
                                <div class="content-discount text-start">
                                  <h5 class="name fw-4">{{ variant.product.title }}</h5>

                                  {% unless variant.product.has_only_default_variant %}
                                    <div class="size">
                                      {% for option_name in variant.product.options %}
                                        {% assign option_value = variant.options[forloop.index0] %}
                                        {% assign is_color = false %}
                                        {% assign downcased_option = option_name | downcase %}
                                        {% if downcased_option contains 'color' or downcased_option contains 'colour' %}
                                          {% assign is_color = true %}
                                        {% endif %}

                                        {% if is_color %}
                                          {% assign color_handle = option_value | handleize %}
                                          {% assign color_rgb = "" %}
                                          {% for option in variant.product.options_with_values %}
                                            {% if option.name == option_name %}
                                              {% for value in option.values %}
                                                {% if value == option_value %}
                                                  {% assign color_rgb = value.swatch.color.rgb %}
                                                {% endif %}
                                              {% endfor %}
                                            {% endif %}
                                          {% endfor %}
                                          
                                          <div class="d-flex align-items-center gap-2">
                                            <div class="text-small text-main-2 sub">{{ option_name }}:</div>
                                            <div class="dot-color"
                                                style="
                                                {% if color_rgb != blank %}
                                                  background-color: rgb({{ color_rgb }}) !important;
                                                {% else %}
                                                  background-color: {{ color_handle }} !important;
                                                {% endif %}
                                                {% if color_handle == 'white' or color_handle == 'whitesmoke' %}
                                                  border: 1px solid #cbcbcb;
                                                {% endif %}
                                              "></div>
                                          </div>
                                        {% elsif option_name == 'Size' %}
                                          <div class="text-small text-main-2 sub">{{ option_name }}: {{ option_value }}</div>
                                        {% endif %}
                                      {% endfor %}
                                    </div>
                                  {% endunless %}
                                {% render 'quantity-input', product: variant.product, product_form_id: product_form_id %}
                                  
                                </div>
                              </div>

                              {% unless forloop.last %}
                                <svg width="31" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
                                  <path
                                    d="M20 4.375C16.9097 4.375 13.8887 5.29139 11.3192 7.00829C8.7497 8.72518 6.74701 11.1655 5.56439 14.0206C4.38177 16.8757 4.07234 20.0173 4.67524 23.0483C5.27813 26.0792 6.76627 28.8633 8.95146 31.0485C11.1367 33.2337 13.9208 34.7219 16.9517 35.3248C19.9827 35.9277 23.1243 35.6182 25.9794 34.4356C28.8345 33.253 31.2748 31.2503 32.9917 28.6808C34.7086 26.1113 35.625 23.0903 35.625 20C35.6205 15.8574 33.9728 11.8858 31.0435 8.95648C28.1143 6.02721 24.1426 4.37955 20 4.375ZM20 34.375C17.1569 34.375 14.3776 33.5319 12.0137 31.9524C9.64973 30.3728 7.80725 28.1278 6.71924 25.5011C5.63123 22.8744 5.34656 19.9841 5.90122 17.1956C6.45588 14.4071 7.82497 11.8457 9.83535 9.83534C11.8457 7.82496 14.4071 6.45587 17.1956 5.90121C19.9841 5.34655 22.8744 5.63122 25.5011 6.71923C28.1278 7.80724 30.3728 9.64972 31.9524 12.0137C33.5319 14.3776 34.375 17.1569 34.375 20C34.3709 23.8112 32.855 27.4652 30.1601 30.1601C27.4652 32.855 23.8112 34.3709 20 34.375ZM26.875 20C26.875 20.1658 26.8092 20.3247 26.6919 20.4419C26.5747 20.5592 26.4158 20.625 26.25 20.625H20.625V26.25C20.625 26.4158 20.5592 26.5747 20.4419 26.6919C20.3247 26.8092 20.1658 26.875 20 26.875C19.8342 26.875 19.6753 26.8092 19.5581 26.6919C19.4409 26.5747 19.375 26.4158 19.375 26.25V20.625H13.75C13.5842 20.625 13.4253 20.5592 13.3081 20.4419C13.1909 20.3247 13.125 20.1658 13.125 20C13.125 19.8342 13.1909 19.6753 13.3081 19.5581C13.4253 19.4408 13.5842 19.375 13.75 19.375H19.375V13.75C19.375 13.5842 19.4409 13.4253 19.5581 13.3081C19.6753 13.1908 19.8342 13.125 20 13.125C20.1658 13.125 20.3247 13.1908 20.4419 13.3081C20.5592 13.4253 20.625 13.5842 20.625 13.75V19.375H26.25C26.4158 19.375 26.5747 19.4408 26.6919 19.5581C26.8092 19.6753 26.875 19.8342 26.875 20Z"
                                    fill="#C8102E" />
                                </svg>
                              {% endunless %}
                            {% endfor %}
                          </div>

                          <button class="tf-btn bg-green w-100 animate-btn btn-add-to-cart effect-flash"
                            type="submit"
                            {%- if product.selected_or_first_available_variant.available == false %} disabled="disabled"{% endif -%}
                            form="{{ product_form_id }}"
                          >
                            Choose this deal
                          </button>
                        {% endform %}
                      </product-form-multi-add>
                    {% endif %}
                  {% when 'volume_discount' %}
                    <product-volume-discount class="tf-product-volume-discount d-block" data-section="{{ section.id }}">
                      <div class="product-badge_item flash-sale w-maxcontent heading">
                        <i class="icon icon-thunder"></i>
                        {{ block.settings.heading }}
                      </div>
                      
                      {% assign product_form_id = 'product-form-volume-' | append: section.id %}
                      {%- form 'product', product, id: product_form_id, class: 'w-100' -%}
                        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                        <input type="hidden" name="quantity" value="{{ block.settings.opt1_qty }}" class="volume-qty-input">
                        
                        <div id="volume-discount-list-{{ section.id }}" class="flat-check-list list-volume-discount">
                          {% for i in (1..3) %}
                            {% capture qty_key %}opt{{ i }}_qty{% endcapture %}
                            {% capture disc_key %}opt{{ i }}_discount{% endcapture %}
                            
                            {% assign qty = block.settings[qty_key] %}
                            {% assign disc = block.settings[disc_key] %}
                            
                            {% if qty > 0 %}
                              {% assign percent_mult = 100.0 | minus: disc | divided_by: 100.0 %}
                              {% assign discounted_unit = product.selected_or_first_available_variant.price | times: percent_mult %}
                              {% assign total_price = discounted_unit | times: qty %}
                              
                              <div class="check-item volume-discount-item {% if forloop.first %}active{% endif %}" data-qty="{{ qty }}" data-discount="{{ disc }}">
                                <div class="content">
                                  <div class="check"><span></span></div>
                                  <h5 class="name fw-6">Buy {{ qty }} item for {{ disc }}% OFF per item</h5>
                                  <div class="tags-save h6">Save {{ disc }}%</div>
                                </div>
                                <h5 class="fw-4 text-end">Total price: <span class="fw-7 price-total">{{ total_price | money }}</span></h5>
                              </div>
                            {% endif %}
                          {% endfor %}
                        </div>
                        <button type="submit" name="add" class="tf-btn animate-btn btn-add-to-cart" style="margin-top:20px;">
                          Choose this deal
                        </button>
                      {%- endform -%}
                    </product-volume-discount>
                  {% when 'volume_discount_thumbnail' %}
                    {% assign discount_products = product.metafields.custom.volume_discount.value %}
                    {% if discount_products != blank %}
                    <product-volume-discount class="tf-product-volume-discount d-block overflow-x-auto" data-section="{{ section.id }}">
                      <div class="product-badge_item flash-sale w-maxcontent heading">
                        <i class="icon icon-thunder"></i>
                        {{ block.settings.heading }}
                      </div>
                      
                      {% assign product_form_id = 'product-form-volume-thumb-' | append: section.id %}
                      {%- form 'product', product, id: product_form_id, class: 'w-100' -%}
                        {% assign first_bundle = discount_products.first %}
                        {% assign first_bundle_qty = block.settings.opt1_qty | default: 1 %}
                        <input type="hidden" name="id" value="{{ first_bundle.selected_or_first_available_variant.id }}">
                        <input type="hidden" name="quantity" value="{{ first_bundle_qty }}" class="volume-qty-input">
                        
                        <div id="volume-discount-list-thumb-{{ section.id }}" class="flat-check-list list-volume-discount-thumbnail">
                          {% for dist_prod in discount_products %}
                            {% assign variant = dist_prod.selected_or_first_available_variant %}
                            {% capture qty_key %}opt{{ forloop.index }}_qty{% endcapture %}
                            {% capture disc_key %}opt{{ forloop.index }}_discount{% endcapture %}
                            {% assign qty = block.settings[qty_key] | default: 1 %}
                            {% assign disc = block.settings[disc_key] | default: 0 %}
                            
                            {% assign base_unit = variant.compare_at_price | default: variant.price | times: qty %}
                            {% assign discounted_unit = variant.price | times: qty %}
                            
                            {% if disc > 0 %}
                              {% assign savings = disc %}
                            {% elsif base_unit > discounted_unit %}
                              {% assign diff = base_unit | minus: discounted_unit %}
                              {% assign savings = diff | times: 100.0 | divided_by: base_unit | round %}
                            {% else %}
                              {% assign savings = 0 %}
                            {% endif %}
                            
                            <div class="check-item volume-discount-thumbnail-item volume-discount-item {% if forloop.first %}active{% endif %}" data-id="{{ variant.id }}" data-qty="{{ qty }}">
                              <div class="image-box">
                                {% assign img = variant.featured_image | default: dist_prod.featured_image %}
                                {% if img != blank %}
