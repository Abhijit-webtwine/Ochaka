<section class="flat-spacing" id="section-{{ section.id }}">
  <div class="container">
    <div class="sect-title type-3 type-2 wow fadeInUp">
      <h2 class="s-title type-semibold">{{ section.settings.heading }}</h2>
      {%- if section.settings.view_all_link != blank -%}
        <a href="{{ section.settings.view_all_link }}" class="tf-btn-icon h6 fw-medium">
          {{ section.settings.view_all_text }}
          <i class="icon icon-caret-circle-right"></i>
        </a>
      {%- endif -%}
    </div>
    <div
      dir="ltr"
      class="swiper tf-swiper wrap-sw-over wow fadeInUp"
      data-preview="{{ section.settings.slides_desktop }}"
      data-tablet="{{ section.settings.slides_tablet }}"
      data-mobile-sm="{{ section.settings.slides_mobile }}"
      data-mobile="1"
      data-space-lg="48"
      data-space-md="24"
      data-space="12"
      data-pagination="1"
      data-pagination-sm="1"
      data-pagination-md="2"
      data-pagination-lg="3"
      data-grid="2"
    >
      <div class="swiper-wrapper">
        {%- assign collection = collections[section.settings.collection] -%}
        {%- if collection != blank and collection.products_count > 0 -%}
          {%- for product in collection.products limit: section.settings.limit -%}
            <div class="swiper-slide">
              {% render 'card-product-mini', product: product %}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..6) -%}
            <div class="swiper-slide">
              <div class="card-product product-style_list-mini type-2 hover-img">
                <div class="card-product_wrapper">
                  <div class="product-img img-style">
                    {{ 'product-apparel-' | append: i | placeholder_svg_tag: 'w-100 placeholder-svg' }}
                  </div>
                </div>
                <div class="card-product_info">
                  <p class="tag-product text-small">Category</p>
                  <h6 class="name-product">
                    <a href="#" class="text-line-clamp-2 link">Product Title Placeholder</a>
                  </h6>
                  <div class="group-action">
                    <div class="price-wrap mb-0">
                      <h4 class="price-new">$0.00</h4>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
      <div class="sw-dot-default tf-sw-pagination"></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Product Swiper",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Product Limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 12
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View All Text",
      "default": "View All Product"
    },
    {
      "type": "url",
      "id": "view_all_link",
      "label": "View All Link"
    },
    {
      "type": "header",
      "content": "Swiper Settings"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Slides Desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_tablet",
      "label": "Slides Tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "Slides Mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    }
  ],
  "presets": [
    {
      "name": "Featured Product Swiper"
    }
  ]
}
{% endschema %}
