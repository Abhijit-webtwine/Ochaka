{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }
{%- endstyle -%}

<section class="flat-spacing section-{{ section.id }}-padding">
  <div class="container">
    <div class="sect-title type-4 wow fadeInUp">
      <h2 class="s-title fw-normal">
        {{- section.settings.heading -}}
      </h2>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_url | default: '#' }}" class="tf-btn-icon h6 fw-medium text-nowrap">
          {{- section.settings.button_label -}}
          <i class="icon icon-caret-circle-right"></i>
        </a>
      {%- endif -%}
    </div>
    <div class="grid-layout-product-2">
      <div class="item-grid-1">
        {%- assign main_product = section.settings.main_product -%}
        {%- if main_product != blank -%}
          <div class="card-product {{ settings.card_spacing }} {{ settings.card_style }} style-pading-4 style-2 tf-cart-item wow fadeInUp">
            <div class="card-product_wrapper aspect-ratio-0 d-flex {% if settings.show_border %} style-line-radius {% endif %}">
              <a href="{{ main_product.url }}" class="product-img">
                <img
                  class="img-product lazyload"
                  src="{{ main_product.featured_image | image_url }}"
                  data-src="{{ main_product.featured_image | image_url }}"
                  alt="{{ main_product.featured_image.alt | default: main_product.title }}"
                  width="{{ main_product.featured_image.width }}"
                  height="{{ main_product.featured_image.height }}"
                >
                {%- if main_product.images[1] != blank -%}
                  <img
                    class="img-hover lazyload"
                    src="{{ main_product.images[1] | image_url }}"
                    data-src="{{ main_product.images[1] | image_url }}"
                    alt="{{ main_product.images[1].alt | default: main_product.title }}"
                    width="{{ main_product.images[1].width }}"
                    height="{{ main_product.images[1].height }}"
                  >
                {%- endif -%}
              </a>
              {% render 'icon-action-list',
                product: main_product,
                show_tooltips: settings.show_tooltips,
                tooltip_direction: settings.tooltip_direction,
                show_wishlist: settings.wishlist_enabled,
                show_compare: settings.compare_enabled,
                show_quick_view: settings.quick_view_enabled,
                show_add_to_cart: false
              %}
            </div>
            <div class="card-product_info d-grid gap-24">
              <div>
                {%- if settings.show_type and main_product.type != blank -%}
                  <p class="tag-product text-small">{{ main_product.type }}</p>
                {%- endif -%}
                <h3>
                  <a href="{{ main_product.url }}" class="name-product link mb-8">
                    {{ main_product.title }}
                  </a>
                </h3>
                {%- if settings.show_rating -%}
                  <div class="infor-rate rate_wrap">
                    {% render 'rating', product: main_product %}
                  </div>
                {%- endif -%}
              </div>
              {%- if settings.show_atc_count -%}
                <div class="people-add text-primary">
                  <add-to-cart-count 
                    min="{{ settings.min_atc_count }}" 
                    max="{{ settings.max_atc_count }}">
                    <div class="add-to-cart-count-container d-flex align-items-center gap-1 w-100">
                      <i class="icon icon-shopping-cart-simple"></i>
                      <p id="view-count" class="visitor-count h6">
                        <span class="vc-number"></span> people just added this product to their cart
                      </p>
                    </div>
                  </add-to-cart-count>
                </div>
              {%- endif -%}
              <div class="price-wrap mb-0">
                {%- liquid
                  assign main_price = main_product.selected_or_first_available_variant.price | money
                  assign main_compare_at_price = main_product.selected_or_first_available_variant.compare_at_price | money
                  if settings.price_style == 'without_trailing_zero'
                    assign main_price = main_product.selected_or_first_available_variant.price | money_without_trailing_zeros
                    assign main_compare_at_price = main_product.selected_or_first_available_variant.compare_at_price | money_without_trailing_zeros
                  endif
                -%}
                {%- if settings.price_position == 'price_last' -%}
                  {%- if main_product.selected_or_first_available_variant.compare_at_price > main_product.selected_or_first_available_variant.price -%}
                    <span class="price-old h4 fw-normal">{{ main_compare_at_price }}</span>
                  {%- endif -%}
                  <span class="price-new h4">{{ main_price }}</span>
                {%- else -%}
                  <span class="price-new h4">{{ main_price }}</span>
                  {%- if main_product.selected_or_first_available_variant.compare_at_price > main_product.selected_or_first_available_variant.price -%}
                    <span class="price-old h4 fw-normal">{{ main_compare_at_price }}</span>
                  {%- endif -%}
                {%- endif -%}
              </div>

              <div class="product-progress_sold">
                <div class="box-quantity">
                  <p class="text-avaiable">
                    {%- if main_product.selected_or_first_available_variant.inventory_quantity > 0 -%}
                      Available: <span class="fw-bold text-black">{{ main_product.selected_or_first_available_variant.inventory_quantity }}</span>
                    {%- else -%}
                      <span class="fw-bold text-black">{{ 'products.product.sold_out' | t | default: 'Sold Out' }}</span>
                    {%- endif -%}
                  </p>
                </div>
              </div>
                <div class="action_quantity-product">
                <product-form class="w-100">
                  {%- assign form_id = 'product-form-' | append: section.id -%}
                  {%- form 'product', main_product, class: 'form', id: form_id -%}
                    <input type="hidden" name="id" value="{{ main_product.selected_or_first_available_variant.id }}">
                    <div class="action_quantity-product d-flex gap-12">
                      {% render 'quantity-input', product: main_product, product_form_id: form_id, classes: 'rounded-0' %}
                      <button 
                        type="submit" 
                        name="add" 
                        class="tf-btn animate-btn w-100 rounded-0 btn-add-to-cart"
                        {%- if main_product.selected_or_first_available_variant.available == false %} disabled="disabled"{% endif -%}
                      >
                        ADD TO CART
                        <i class="icon icon-shopping-cart-simple"></i>
                      </button>
                    </div>
                  {%- endform -%}
                </product-form>
              </div>
            </div>
          </div>
        {%- else -%}
          <div class="card-product {{ settings.card_spacing }} {{ settings.card_style }} style-pading-4 style-2 tf-cart-item wow fadeInUp">
            <div class="card-product_wrapper aspect-ratio-0 d-flex {% if settings.show_border %} style-line-radius {% endif %}">
              <div class="product-img">
                {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
              </div>
            </div>
            <div class="card-product_info d-grid gap-24">
              <div>
                <p class="tag-product text-small">Category</p>
                <h3>
                  <span class="name-product mb-8">Product Title Placeholder</span>
                </h3>
              </div>
              <div class="price-wrap mb-0">
                <span class="price-new h4">$99.00</span>
              </div>

              <div class="product-progress_sold">
                <div class="box-quantity">
                  <p class="text-avaiable">
                    Available: <span class="fw-bold text-black">10</span>
                  </p>
                </div>
              </div>
              <div class="action_quantity-product">
                <div class="action_quantity-product d-flex gap-12">
                  <button type="button" class="tf-btn animate-btn w-100 rounded-0 btn-add-to-cart">
                    ADD TO CART
                    <i class="icon icon-shopping-cart-simple"></i>
                  </button>
                </div>
              </div>
            </div>
          </div>
        {%- endif -%}
      </div>
      <div class="item-grid-2">
        {%- assign collection = collections[section.settings.collection] -%}
        <div
          dir="ltr"
          class="swiper tf-swiper wow fadeInUp"
          data-preview="{{ section.settings.slides_desktop }}"
          data-tablet="{{ section.settings.slides_tablet }}"
          data-mobile-sm="{{ section.settings.slides_mobile }}"
          data-mobile="1"
          data-space-lg="{{ section.settings.space_desktop }}"
          data-space-md="{{ section.settings.space_tablet }}"
          data-space="{{ section.settings.space_mobile }}"
          data-pagination="1"
          data-pagination-sm="2"
          data-pagination-md="2"
          data-pagination-lg="3"
        >
          <div class="swiper-wrapper">
            {%- assign collection = collections[section.settings.collection] -%}
            {%- if collection != blank -%}
              {%- assign slide_count = section.settings.products_to_show | divided_by: 2 -%}
              {%- for i in (1..slide_count) -%}
                {%- assign index1 = i | minus: 1 | times: 2 -%}
                {%- assign index2 = index1 | plus: 1 -%}
                {%- assign prod1 = collection.products[index1] -%}
                {%- assign prod2 = collection.products[index2] -%}
                
                {%- if prod1 != blank -%}
                  <div class="swiper-slide">
                    <div class="list-ver gap-4">
                      {% render 'card-product', 
                        product: prod1, 
                        card_class: 'style-5 style-padding-3 bg-min-white',
                        show_add_to_cart: true,
                        show_wishlist: settings.wishlist_enabled,
                        show_compare: settings.compare_enabled,
                        show_quick_view: settings.quick_view_enabled
                      %}
                      {%- if prod2 != blank -%}
                        {% render 'card-product', 
                          product: prod2, 
                          card_class: 'style-5 style-padding-3 bg-min-white',
                          show_add_to_cart: true,
                          show_wishlist: settings.wishlist_enabled,
                          show_compare: settings.compare_enabled,
                          show_quick_view: settings.quick_view_enabled
                        %}
                      {%- endif -%}
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            {%- else -%}
              {%- for i in (1..3) -%}
                <div class="swiper-slide">
                  <div class="list-ver gap-4">
                    {%- for j in (1..2) -%}
                      <div class="card-product style-5 style-padding-3 bg-min-white">
                        <div class="card-product_wrapper aspect-ratio-0">
                          {%- capture current -%}{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                          {{ 'product-apparel-' | append: current | placeholder_svg_tag: 'placeholder-svg w-100 h-100' }}
                        </div>
                        <div class="card-product_info">
                          <h4 class="name-product">Product Example</h4>
                          <span class="price">$10.00</span>
                        </div>
                      </div>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endfor -%}
            {%- endif -%}
          </div>
          <div class="sw-dot-default d-xl-none tf-sw-pagination"></div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Deal Today",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Deal of the day"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "View All Product"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Main Product (Left)"
    },
    {
      "type": "product",
      "id": "main_product",
      "label": "Main Product"
    },
    {
      "type": "header",
      "content": "Product Carousel (Right)"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 2,
      "default": 6
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Slides Desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_tablet",
      "label": "Slides Tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "Slides Mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Slider Spacing"
    },
    {
      "type": "range",
      "id": "space_desktop",
      "label": "Spacing Desktop",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "space_tablet",
      "label": "Spacing Tablet",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "space_mobile",
      "label": "Spacing Mobile",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "header",
      "content": "Tablet padding"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Deal Today"
    }
  ]
}
{% endschema %}
