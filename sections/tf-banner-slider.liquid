<div class="tf-slideshow tf-btn-swiper-main" id="Section-{{ section.id }}">
  <div class="container-full-2">
    <div class="slideshow-container">
      <div
        dir="ltr"
        class="swiper tf-swiper sw-slide-show slider_effect_fade"
        data-auto="true"
        data-loop="true"
        data-effect="fade"
        data-delay="3000"
      >
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <div class="slider-wrap style-5">
                <div class="sld_image type-radius">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 2000 }}"
                      data-src="{{ block.settings.image | image_url: width: 2000 }}"
                      alt="{{ block.settings.title | escape }}"
                      class="lazyload scale-item sale-item-1"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                    >
                  {%- else -%}
                    {{ 'hero-apparel-1' | placeholder_svg_tag: 'lazyload scale-item sale-item-1 placeholder-svg' }}
                  {%- endif -%}
                </div>
                {%- if block.settings.alignment == 'left' -%}
                  <div class="sld_content type-3">
                    {%- render 'slide_content' with slide_block: block -%}
                  </div>
                {%- else -%}
                  <div class="sld_content text-center">
                    <div class="container">
                      {%- render 'slide_content' with slide_block: block -%}
                    </div>
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
        <div class="sw-dot-default style-white tf-sw-pagination"></div>
      </div>
      <div class="col-right d-md-none d-xl-block">
        <div class="box-image_V01 type-4 hover-img h-100">
          <a href="{{ section.settings.banner_btn_link | default: '#' }}" class="box-image_image img-style">
            {%- if section.settings.banner_img != blank -%}
              <img
                src="{{ section.settings.banner_img | image_url: width: 1000 }}"
                data-src="{{ section.settings.banner_img | image_url: width: 1000 }}"
                alt="{{ section.settings.banner_img.alt | escape }}"
                class="h-100 lazyload"
                width="{{ section.settings.banner_img.width }}"
                height="{{ section.settings.banner_img.height }}"
              >
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'h-100 lazyload placeholder-svg' }}
            {%- endif -%}
          </a>
          <div class="box-image_content align-items-center text-center">
            {%- if section.settings.banner_sub_title != blank -%}
              <h4 class="sub-title text-primary mb-16">{{ section.settings.banner_sub_title }}</h4>
            {%- endif -%}
            {%- if section.settings.banner_title != blank -%}
              <a
                href="{{ section.settings.banner_btn_link | default: '#' }}"
                class="title link primary-2 h2 fw-semibold mb-32"
              >
                {{ section.settings.banner_title |  newline_to_br }}
              </a>
            {%- endif -%}
            {%- if section.settings.banner_btn_text != blank -%}
              <a
                href="{{ section.settings.banner_btn_link | default: '#' }}"
                class="tf-btn bg-primary primary-2 animate-btn"
              >
                {{ section.settings.banner_btn_text }}
                <i class="icon icon-arrow-right"></i>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Banner Slider",
  "settings": [
    {
      "type": "header",
      "content": "Right Banner Settings"
    },
    {
      "type": "image_picker",
      "id": "banner_img",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "banner_sub_title",
      "label": "Sub Title",
      "default": "SALE OFF 50%"
    },
    {
      "type": "textarea",
      "id": "banner_title",
      "label": "Title",
      "default": "Fresh fruit for <br>a healthy body"
    },
    {
      "type": "text",
      "id": "banner_btn_text",
      "label": "Button Text",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "banner_btn_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "sub_title",
          "label": "Sub Title",
          "default": "SALE OFF 50%"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Title",
          "default": "A Rich Source Of Vitamins <br>From Nature"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "Button Link"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Content Alignment",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            }
          ],
          "default": "left"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Slider",
      "blocks": [
        {
          "type": "slide"
        },
        {
          "type": "slide"
        },
        {
          "type": "slide",
          "settings": {
            "alignment": "center"
          }
        }
      ]
    }
  ]
}
{% endschema %}
