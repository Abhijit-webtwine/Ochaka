{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  /* Pre-initialization Swiper styles to prevent layout shift */
  .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    flex-wrap: nowrap;
    overflow: hidden;
    gap: 12px;
  }
  .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
    width: 100%;
    flex: 0 0 auto;
  }
  
  @media (min-width: 768px) {
    .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-wrapper {
      gap: 24px;
    }
    .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
      width: calc((100% - (2 - 1) * 24px) / 2);
    }
  }
  
  @media (min-width: 1200px) {
    .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-wrapper {
      gap: 48px;
    }
    .section-{{ section.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
      width: calc((100% - (3 - 1) * 48px) / 3);
    }
  }
{%- endstyle -%}

<section class="flat-spacing section-{{ section.id }}-padding section-{{ section.id }}-swiper" data-section-id="{{ section.id }}">
  <div class="container">
    {%- if section.settings.title != blank or section.settings.link_text != blank -%}
      <div class="sect-title type-4 wow fadeInUp">
        {%- if section.settings.title != blank -%}
          <h2 class="s-title fw-normal">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.link_text != blank -%}
          <a href="{{ section.settings.link_url | default: '#' }}" class="tf-btn-line">
            {{ section.settings.link_text }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
    <div dir="ltr" class="swiper tf-swiper wow fadeInUp" data-preview="3" data-tablet="2" data-mobile-sm="1" data-mobile="1"
      data-space-xxl="48" data-space-lg="32" data-space-md="24" data-space="12" data-pagination="1" data-pagination-sm="1"
      data-pagination-md="2" data-pagination-lg="3">
      <div class="swiper-wrapper">
        {%- for block in section.blocks -%}
          {%- if block.type == 'product_list' -%}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <div class="list-ver gap-24">
                {%- if block.settings.product_1 != blank -%}
                  {% render 'card-product-mini', product: block.settings.product_1, card_class: 'style-border' %}
                {%- else -%}
                  <div class="card-product product-style_list-mini type-2 style-border hover-img bg-white">
                    <div class="card-product_wrapper">
                      <div class="product-img img-style w-100 h-100">
                        {{ 'product-apparel-1' | placeholder_svg_tag: 'img-product lazyload bg-light w-100 h-100' }}
                      </div>
                    </div>
                    <div class="card-product_info">
                      <p class="tag-product text-small">Category</p>
                      <a href="#" class="name-product h6 fw-medium text-line-clamp-2 link">Example Product 1</a>
                      <div class="group-action">
                        <div class="price-wrap mb-0">
                          <span class="price-new h6">{{ 1999 | money }}</span>
                          <span class="price-old h6 fw-normal text-decoration-line-through">{{ 2999 | money }}</span>
                        </div>
                      </div>
                    </div>
                  </div>
                {%- endif -%}
                
                {%- if block.settings.product_2 != blank -%}
                  {% render 'card-product-mini', product: block.settings.product_2, card_class: 'style-border' %}
                {%- else -%}
                  <div class="card-product product-style_list-mini type-2 style-border hover-img bg-white">
                    <div class="card-product_wrapper">
                      <div class="product-img img-style w-100 h-100">
                        {{ 'product-apparel-2' | placeholder_svg_tag: 'img-product lazyload bg-light w-100 h-100' }}
                      </div>
                    </div>
                    <div class="card-product_info">
                      <p class="tag-product text-small">Category</p>
                      <a href="#" class="name-product h6 fw-medium text-line-clamp-2 link">Example Product 2</a>
                      <div class="group-action">
                        <div class="price-wrap mb-0">
                          <span class="price-new h6">{{ 7800 | money }}</span>
                          <span class="price-old h6 fw-normal text-decoration-line-through">{{ 9500 | money }}</span>
                        </div>
                      </div>
                    </div>
                  </div>
                {%- endif -%}
              </div>
            </div>
          {%- elsif block.type == 'deal' -%}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <div class="card-product product-style_list-mini type-3 style-border hover-img bg-white">
                <div class="card-product_wrapper d-flex aspect-ratio-0">
                  <div class="product-img img-style w-100 h-100">
                    {%- if block.settings.product != blank and block.settings.product.featured_media -%}
                      <img class="img-product lazyload" src="{{ block.settings.product.featured_media | image_url: width: 600 }}"
                        data-src="{{ block.settings.product.featured_media | image_url: width: 600 }}" alt="{{ block.settings.product.title }}" width="{{ block.settings.product.featured_media.width }}" height="{{ block.settings.product.featured_media.height }}">
                    {%- else -%}
                      {{ 'product-apparel-3' | placeholder_svg_tag: 'img-product lazyload bg-light w-100 h-100' }}
                    {%- endif -%}
                  </div>
                </div>
                <div class="card-product_info">
                  <div>
                    {%- if block.settings.product != blank -%}
                      <a href="{{ block.settings.product.url }}" class="name-product h4 fw-medium link">
                        {{ block.settings.product.title }}
                      </a>
                    {%- else -%}
                      <p class="tag-product text-small">Featured Deal</p>
                      <a href="#" class="name-product h4 fw-medium text-line-clamp-2 link">Example Main Deal Product Title</a>
                    {%- endif -%}
                    <div class="rate_wrap">
                      <i class="icon-star text-star"></i>
                      <i class="icon-star text-star"></i>
                      <i class="icon-star text-star"></i>
                      <i class="icon-star text-star"></i>
                      <i class="icon-star text-star"></i>
                    </div>
                  </div>
                  <div class="product-progress_sold primary-3">
                    {%- liquid
                       if block.settings.product != blank
                         assign available = block.settings.product.selected_or_first_available_variant.inventory_quantity
                       endif
                    -%}
                    <div class="box-quantity">
                      <p class="text-avaiable">
                        {%- if available > 0 -%}
                          Available: <span class="fw-bold text-black">{{ available }}</span>
                        {%- else -%}
                          <span class="fw-bold text-black">{{ 'products.product.sold_out' | t | default: 'Sold Out' }}</span>
                        {%- endif -%}
                      </p>
                    </div>
                  </div>
                  <div class="price-wrap mb-0">
                    {%- if block.settings.product != blank -%}
                      <h4 class="price-new">{{ block.settings.product.price | money }}</h4>
                      {%- if block.settings.product.compare_at_price > block.settings.product.price -%}
                        <span class="price-old h6 fw-normal text-decoration-line-through">{{ block.settings.product.compare_at_price | money }}</span>
                      {%- endif -%}
                    {%- else -%}
                      <h4 class="price-new">{{ 14400 | money }}</h4>
                      <span class="price-old h6 fw-normal text-decoration-line-through">{{ 15800 | money }}</span>
                    {%- endif -%}
                  </div>
                  <div class="w-100">
                    {% if block.settings.product != blank %}
                      {% render 'icon-add-to-cart', type: 'button', product: block.settings.product %}
                    {% else %}
                      <button class="tf-btn animate-btn w-100 btn-add-to-cart" disabled>
                        ADD TO CART
                        <i class="icon icon-shopping-cart-simple"></i>
                      </button>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="sw-dot-default tf-sw-pagination"></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Deals Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Best Sellers"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "header",
      "content": "Tablet padding"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "product_list",
      "name": "Product List (2 items)",
      "limit": 4,
      "settings": [
        {
          "type": "product",
          "id": "product_1",
          "label": "First Product"
        },
        {
          "type": "product",
          "id": "product_2",
          "label": "Second Product"
        }
      ]
    },
    {
      "type": "deal",
      "name": "Main Deal",
      "limit": 2,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Deals Grid",
      "blocks": [
        {
          "type": "product_list"
        },
        {
          "type": "deal"
        },
        {
          "type": "product_list"
        }
      ]
    }
  ]
}
{% endschema %}