{% style %}
  .section-{{ section.id }}-review-decor {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-review-decor {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-review-decor {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }
{% endstyle %}

<section class="section-{{ section.id }}-review-decor">
  <div class="tf-sw-thumbs tes_thumb">
    <div class="container">
      <div class="s-banner-tes">
        <div class="col-left">
          {% if section.settings.heading != blank %}
            <h1 class="s-title sect-title wow fadeInUp">{{ section.settings.heading }}</h1>
          {% endif %}
          <div dir="ltr" class="swiper sw-thumb sw-tes-thumb wow fadeInUp">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                <div class="swiper-slide" {{ block.shopify_attributes }}>
                  <div class="testimonial-V03">
                    <div class="tes_icon">
                      <i class="icon icon-block-quote"></i>
                    </div>
                    <div class="d-grid">
                      {% if block.settings.title != blank %}
                        <h4 class="tes_title">{{ block.settings.title }}</h4>
                      {% endif %}
                      {% if block.settings.text != blank %}
                        <p class="tes_text h4">
                          {{ block.settings.text }}
                        </p>
                      {% endif %}
                      <div class="tes_author">
                        {% if block.settings.author != blank %}
                          <p class="author-name h4">{{ block.settings.author }}</p>
                        {% endif %}
                        {% if block.settings.verified %}
                          <i class="author-verified icon-check-circle"></i>
                        {% endif %}
                      </div>
                      {% render 'testimonial-review', rating: block.settings.rating %}
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>
          </div>
          <div class="group-btn-slider wow fadeInUp">
            <div class="tf-sw-nav style-2 type-small nav-prev-swiper">
              <i class="icon icon-caret-left"></i>
            </div>
            <div class="tf-sw-nav style-2 type-small nav-next-swiper">
              <i class="icon icon-caret-right"></i>
            </div>
          </div>
        </div>
        <div class="col-right">
          {% if section.settings.main_image != blank %}
            <div class="s-image overflow-hidden">
              <img class="ani-zoom lazyload" 
                src="{{ section.settings.main_image | image_url }}" 
                data-src="{{ section.settings.main_image | image_url }}"
                alt="{{ section.settings.main_image.alt | escape }}"
              >
            </div>
          {% endif %}
          <div dir="ltr" class="swiper sw-main-thumb sw-tes wow fadeInUp">
            <div class="swiper-wrapper">
              {% for block in section.blocks %}
                <div class="swiper-slide">
                  {% if block.settings.product != blank %}
                    {% assign product = block.settings.product %}
                    <div class="product-thumbs">
                      <div class="image">
                        {% if product.featured_image != blank %}
                          <img class="lazyload" 
                            src="{{ product.featured_image | image_url }}" 
                            data-src="{{ product.featured_image | image_url }}"
                            alt="{{ product.title | escape }}"
                          >
                        {% else %}
                          {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                        {% endif %}
                      </div>
                      <div class="content">
                        <a href="{{ product.url }}" class="link h4 name text-black">
                          {{ product.title }}
                        </a>
                        <p class="h6 price text-black">{{ product.price | money_without_trailing_zeros }}</p>
                      </div>
                    </div>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Review Decor",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Customer Reviews"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Padding Top Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom Desktop",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Top Tablet",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom Tablet",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Top Mobile",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "label": "Padding Bottom Mobile",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Dedicated service"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Guy Hawkins"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Verified Purchase",
          "default": true
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Review Decor",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "title": "Dedicated service",
            "text": "Lorem ipsum dolor sit amet, consectetur adipiscing elit.",
            "author": "Guy Hawkins",
            "rating": 5
          }
        },
        {
          "type": "review",
          "settings": {
            "title": "Best Product Quality",
            "text": "Lorem ipsum dolor sit amet, consectetur adipiscing elit.",
            "author": "Mas Shin",
            "rating": 5
          }
        }
      ]
    }
  ]
}
{% endschema %}