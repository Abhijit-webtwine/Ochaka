<style>
  .section-{{ section.id }}-banner-swiper {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-banner-swiper {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    .section-{{ section.id }}-banner-swiper {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }
</style>

<div class="themesFlat section-{{ section.id }}-banner-swiper">
  <div class="container">
    <div
      dir="ltr"
      class="swiper tf-swiper"
      data-preview="{{ section.settings.slides_desktop }}"
      data-tablet="{{ section.settings.slides_tablet }}"
      data-mobile-sm="{{ section.settings.slides_mobile }}"
      data-mobile="1"
      data-space-lg="{{ section.settings.space_desktop }}"
      data-space-md="{{ section.settings.space_tablet }}"
      data-space="{{ section.settings.space_mobile }}"
      data-pagination="1"
      data-pagination-sm="2"
      data-pagination-md="2"
      data-pagination-lg="3"
    >
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% if block.type == 'banner_item' %}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              {% liquid
                if section.settings.card_style == 'v05'
                  assign is_v05 = true
                endif
                
                assign sale_class = 'fw-bold'
                assign button_class = 'tf-btn-line letter-space-0'
                assign wrap_image_link = false
                assign title_variant = 'v06'
                if is_v05
                  assign sale_class = 'fw-semibold'
                  assign button_class = 'tf-btn-line fw-bold letter-space-0'
                  assign wrap_image_link = true
                  assign title_variant = 'v05'
                endif
              %}
              <div class="{{ section.settings.box_type }} {{ section.settings.spacing_type }} hover-img wow fadeInLeft"{% if forloop.index > 1 %} data-wow-delay="{{ forloop.index0 | times: 0.1 }}s"{% endif %}>
                {% if block.settings.badge != blank %}
                  <ul class="product-badge_list">
                    <li class="product-badge_item fw-normal h6" style="background-color: {{ block.settings.badge_color }};color: {{ block.settings.badge_text_color }}">
                      {{ block.settings.badge }}
                    </li>
                  </ul>
                {% endif %}
                {% if wrap_image_link and block.settings.link != blank %}
                  <a href="{{ block.settings.link }}" class="box-image_image img-style">
                    {% if block.settings.image != blank %}
                      {{
                        block.settings.image
                        | image_url: width: 800
                        | image_tag:
                          class: 'lazyload',
                          loading: 'lazy',
                          alt: block.settings.image.alt | default: block.settings.title | default: 'Banner'
                      }}
                    {% else %}
                      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %}
                  </a>
                {% else %}
                  <div class="box-image_image img-style">
                    {% if block.settings.image != blank %}
                      {{
                        block.settings.image
                        | image_url: width: 800
                        | image_tag:
                          class: 'lazyload',
                          loading: 'lazy',
                          alt: block.settings.image.alt | default: block.settings.title | default: 'Banner'
                      }}
                    {% else %}
                      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %}
                  </div>
                {% endif %}

                <div class="box-image_content">
                  <div>
                    {% if block.settings.sale_text != blank %}
                      <p class="{{ sale_class }} sub-title h6 text-primary">
                        {{ block.settings.sale_text }}
                      </p>
                    {% endif %}

                    {% if block.settings.title != blank %}
                      {% if title_variant == 'v05' %}
                        <h4 class="title">
                          <a href="{{ block.settings.link | default: '#' }}" class="link">
                            {{ block.settings.title }}
                          </a>
                        </h4>
                      {% else %}
                        <a
                          href="{{ block.settings.link | default: '#' }}"
                          class="title link text-display-3 fw-semibold"
                        >
                          {{ block.settings.title }}
                        </a>
                      {% endif %}
                    {% endif %}

                    {% if block.settings.subtitle != blank %}
                      <div class="sub-title h6 fw-bold text-main-6">
                        {{ block.settings.subtitle }}
                      </div>
                    {% endif %}
                  </div>
                  {% if block.settings.button_text != blank %}
                    <a href="{{ block.settings.link | default: '#' }}" class="{{ button_class }}">
                      {{ block.settings.button_text }}
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <div class="sw-dot-default tf-sw-pagination"></div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Banner Swiper",
  "max_blocks": 10,
  "settings": [
    {
      "type": "select",
      "id": "card_style",
      "label": "Card Style",
      "options": [
        { "value": "v06", "label": "Large Title" },
        { "value": "v05", "label": "Medium Title" }
      ],
      "default": "v06"
    },
    {
      "type": "select",
      "id": "box_type",
      "label": "Box Type",
      "default": "box-image_V06",
      "options": [
        {
          "value": "box-image_V06",
          "label": "Rounded Corners"
        },
        {
          "value": "box-image_V05",
          "label": "Pointed Corners"
        }
      ]
    },
    {
      "type": "select",
      "id": "spacing_type",
      "label": "Spacing Type",
      "default": "type-space-1",
      "options": [
        {
          "value": "type-space-1",
          "label": "Loose"
        },
        {
          "value": "type-space-2",
          "label": "Tight"
        }
      ]
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Slides Desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_tablet",
      "label": "Slides Tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "Slides Mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Slider Spacing"
    },
    {
      "type": "range",
      "id": "space_desktop",
      "label": "Spacing Desktop",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 48
    },
    {
      "type": "range",
      "id": "space_tablet",
      "label": "Spacing Tablet",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "space_mobile",
      "label": "Spacing Mobile",
      "min": 0,
      "max": 60,
      "step": 1,
      "default": 12
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "header",
      "content": "Tablet padding"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "banner_item",
      "name": "Banner Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "sale_text",
          "label": "Sale Text"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title",
        },
        {
          "type": "richtext",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge"
        },
        {
          "type": "color",
          "id": "badge_color",
          "label": "Badge color"
        },
        {
          "type": "color",
          "id": "badge_text_color",
          "label": "Badge text color",
          "default": "#fff"
        },
        {
          "type": "header",
          "content": "Button"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "Discover more"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Swiper",
      "category": "Banner",
      "blocks": [
        {
          "type": "banner_item",
          "settings": {
            "title": "<p>Book Your Summer</p>",
            "subtitle": "<p>Get a voucher for any order over $150</p>",
            "button_text": "Discover more"
          }
        },
        {
          "type": "banner_item",
          "settings": {
            "title": "<p>Good books every day</p>",
            "sale_text": "SALE upto 50%",
            "button_text": "Shop now"
          }
        },
        {
          "type": "banner_item",
          "settings": {
            "title": "<p>By readers</p>",
            "subtitle": "<p>The best and most meaningful books recommended by readers</p>",
            "button_text": "Get a voucher"
          }
        }
      ]
    }
  ]
}
{% endschema %}
