{% style %}
  #shopify-block-{{ block.id }} {
    padding-top: {{ block.settings.padding_top_mobile }}px;
    padding-bottom: {{ block.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    #shopify-block-{{ block.id }} {
      padding-top: {{ block.settings.padding_top_tablet }}px;
      padding-bottom: {{ block.settings.padding_bottom_tablet }}px;
    }
  }

  @media screen and (min-width: 1025px) {
    #shopify-block-{{ block.id }} {
      padding-top: {{ block.settings.padding_top_desktop }}px;
      padding-bottom: {{ block.settings.padding_bottom_desktop }}px;
    }
  }

  {% if block.settings.show_date == 'tag' %}
    #shopify-block-{{ block.id }} .entry_tag .name-tag {
      background-color: {{ block.settings.date_color }};
    }
  {% endif %}
{% endstyle %}

<div class="featured-blog-block">
  {% render 'featured-blog-block', block: block %}
</div>

{% schema %}
{
  "name": "Featured Blog",
  "settings": [
    {
      "type": "header",
      "content": "Blog Configuration"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Select blog"
    },
    {
      "type": "range",
      "id": "posts_limit",
      "label": "Number of posts",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "blog_style",
      "label": "Blog Style",
      "options": [
        { "value": "", "label": "Default" },
        { "value": "type-space-2", "label": "Extended Space" }
      ],
      "default": ""
    },
    {
      "type": "checkbox",
      "id": "disable_content_spacing",
      "label": "Disable Content Spacing",
      "default": false,
      "visible_if": "{{ block.settings.blog_style == '' }}"
    },
    {
      "type": "header",
      "content": "Card Settings"
    },
    {
      "type": "select",
      "id": "card_layout",
      "label": "Card Corners",
      "options": [
        { "value": "style-radius", "label": "Rounded" },
        { "value": "", "label": "Sharp" }
      ],
      "default": ""
    },
    {
      "type": "select",
      "id": "show_date",
      "label": "Show Date Style",
      "options": [
        { "value": "tag", "label": "Tag (on top)" },
        { "value": "date", "label": "Date (under title)" }
      ],
      "default": "tag"
    },
    {
      "type": "color",
      "id": "date_color",
      "label": "Date Tag Background",
      "default": "#000000",
      "visible_if": "{{ block.settings.show_date == 'tag' }}"
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show Excerpt",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_read_more",
      "label": "Show Read More Link",
      "default": true
    },
    {
      "type": "text",
      "id": "read_more_text",
      "label": "Read More Label",
      "default": "Read more",
      "visible_if": "{{ block.settings.show_read_more == true }}"
    },
    {
      "type": "header",
      "content": "Header Settings"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Read Our Blog"
    },
    {
      "type": "select",
      "id": "heading_style",
      "label": "Heading Size",
      "options": [
        { "value": "true", "label": "Large" },
        { "value": "false", "label": "Small" }
      ],
      "default": "true"
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Weight",
      "options": [
        { "value": "normal", "label": "Normal" },
        { "value": "medium", "label": "Medium" },
        { "value": "semibold", "label": "Semi-bold" },
        { "value": "none", "label": "None" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "header_layout",
      "label": "Header Layout",
      "options": [
        { "value": "with_subtitle", "label": "With Subtitle" },
        { "value": "with_button_and_icon", "label": "With Button and Icon" },
        { "value": "with_nav", "label": "With Navigation" }
      ],
      "default": "with_subtitle"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Up to 50% off Lorem ipsum dolor sit amet, consectetur adipiscing elit",
      "visible_if": "{{ block.settings.header_layout == 'with_subtitle' }}"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link",
      "visible_if": "{{ block.settings.header_layout == 'with_button_and_icon' }}"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All",
      "visible_if": "{{ block.settings.header_layout == 'with_button_and_icon' }}"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Heading Alignment",
      "options": [
        { "value": "justify-content-between", "label": "Left" },
        { "value": "justify-content-center text-center", "label": "Center" },
        { "value": "justify-content-end", "label": "Right" }
      ],
      "default": "justify-content-center text-center",
      "visible_if": "{{ block.settings.header_layout == 'with_subtitle' }}"
    },
    {
      "type": "select",
      "id": "header_spacing",
      "label": "Header Spacing",
      "options": [
        { "value": "type-4", "label": "Default" },
        { "value": "", "label": "Extended Space With Border" }
      ],
      "default": "type-4"
    },
    {
      "type": "header",
      "content": "Slider Configuration"
    },
    {
      "type": "range",
      "id": "slides_to_show_desktop",
      "label": "Slides per Desktop",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_to_show_tablet",
      "label": "Slides per Tablet",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_to_show_mobile",
      "label": "Slides per Mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_spacing_desktop",
      "label": "Spacing Desktop",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 48
    },
    {
      "type": "range",
      "id": "slides_spacing_tablet",
      "label": "Spacing Tablet",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 24
    },
    {
      "type": "range",
      "id": "slides_spacing_mobile",
      "label": "Spacing Mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 12
    },
    {
      "type": "header",
      "content": "Desktop Padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 112
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 112
    },
    {
      "type": "header",
      "content": "Tablet Padding"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding Bottom",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile Padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Featured Blog"
    }
  ]
}
{% endschema %}
