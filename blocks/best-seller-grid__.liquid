<style>
  #shopify-block-{{ block.id }} {
    background-color: {{ block.settings.background_color }};
  }

  /* Pre-initialization Swiper styles to prevent layout shift */
  .block-{{ block.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    flex-wrap: nowrap;
    overflow: hidden;
    gap: 24px;
  }
  .block-{{ block.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
    width: 100%;
    flex: 0 0 auto;
  }
  
  /* Product slider in item-grid-2 */
  @media (min-width: 768px) {
    .block-{{ block.id }}-swiper .item-grid-2 .tf-swiper:not(.swiper-initialized) .swiper-slide {
      width: calc((100% - (2 - 1) * 24px) / 2);
    }
  }
  
  @media (min-width: 1200px) {
    .block-{{ block.id }}-swiper .item-grid-2 .tf-swiper:not(.swiper-initialized) .swiper-slide {
      width: calc((100% - (3 - 1) * 24px) / 3);
    }
  }

  /* Media slider for main product */
  .block-{{ block.id }}-swiper .flat-wrap-media-product .tf-swiper:not(.swiper-initialized) .swiper-slide {
    width: 100%;
  }
</style>

{% capture grid_content %}
  {% render 'best-seller-grid-block', section: block %}
{% endcapture %}

{% render 'product-swiper-wrapper', id: block.id, settings: block.settings, content: grid_content %}

{% schema %}
{
  "name": "Best Seller Grid",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our Best Sellers"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All Product"
    },
    {
      "type": "product",
      "id": "main_product",
      "label": "Main Product"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 3,
      "label": "Products Limit"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "header",
      "content": "Tablet padding"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Best Seller Grid"
    }
  ]
}
{% endschema %}
