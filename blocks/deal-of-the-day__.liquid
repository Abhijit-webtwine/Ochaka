<style>
  #shopify-block-{{ block.id }} {
    background-color: {{ block.settings.background_color }};
  }

  /* Pre-initialization Swiper styles to prevent layout shift */
  .block-{{ block.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-wrapper {
    display: flex;
    flex-wrap: nowrap;
    overflow: hidden;
    gap: 24px;
  }
  .block-{{ block.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
    width: 100%;
    flex: 0 0 auto;
  }
  
  @media (min-width: 576px) {
    .block-{{ block.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
      width: calc((100% - ({{ block.settings.slides_mobile | default: 1 }} - 1) * 24px) / {{ block.settings.slides_mobile | default: 1 }});
    }
  }

  @media (min-width: 768px) {
    .block-{{ block.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
      width: calc((100% - ({{ block.settings.slides_tablet | default: 2 }} - 1) * 24px) / {{ block.settings.slides_tablet | default: 2 }});
    }
  }
  
  @media (min-width: 1200px) {
    .block-{{ block.id }}-swiper .tf-swiper:not(.swiper-initialized) .swiper-slide {
      width: calc((100% - ({{ block.settings.slides_desktop | default: 3 }} - 1) * 24px) / {{ block.settings.slides_desktop | default: 3 }});
    }
  }
</style>

{% capture deal_content %}
  {% render 'deal-of-the-day-block', section: block %}
{% endcapture %}

{% render 'product-swiper-wrapper', id: block.id, settings: block.settings, content: deal_content %}

{% schema %}
{
  "name": "Deal Of The Day",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Deal Of The Day"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "View All Product"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_limit",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Products Limit"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Slides Desktop",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "slides_tablet",
      "label": "Slides Tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "Slides Mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 1
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Desktop padding"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 112
    },
    {
      "type": "header",
      "content": "Tablet padding"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Mobile padding"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Deal Of The Day"
    }
  ]
}
{% endschema %}
